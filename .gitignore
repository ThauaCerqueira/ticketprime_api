# Ignora pastas bin e obj em qualquer subpasta
**/bin/
**/obj/

# Ignora configurações do VS Code
.vscode/

# Nunca versionar arquivos com credenciais — use dotnet user-secrets ou variáveis de ambiente
src/appsettings.Development.json
ui/TicketPrime.Web/appsettings.Development.json
**/appsettings.Production.json
**/secrets.json

# Ignora certificados SSL auto-assinados gerados localmente
docker/nginx/certs/

# Ignora arquivos de ambiente com credenciais
.env

# Ignora cache do .NET (lscache)
*.lscache
