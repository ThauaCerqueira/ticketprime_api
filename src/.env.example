# Variáveis de ambiente para produção — convenção .NET (__ separa seções)
# Copie este arquivo, renomeie para .env e preencha os valores.
# NUNCA comite o arquivo .env preenchido.

# ── Banco de dados ──────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=<host>,1433;Database=TicketPrime;User Id=<user>;Password=<senha>;TrustServerCertificate=False;Encrypt=True;

# ── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres, gerado com: openssl rand -hex 32
Jwt__Key=<mínimo-32-caracteres-gerado-aleatoriamente>
Jwt__ExpireMinutes=15

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EmailSettings__SmtpHost=smtp.sendgrid.net
EmailSettings__SmtpPort=587
EmailSettings__SmtpUsername=apikey
EmailSettings__SmtpPassword=<sendgrid-api-key>
EmailSettings__FromEmail=noreply@seudominio.com.br
EmailSettings__FromName=TicketPrime

# ── Pagamento ────────────────────────────────────────────────────────────────
MercadoPago__AccessToken=<token-mercadopago-producao>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Múltiplas origens separadas pelo índice:
# AllowedOrigins__0=https://seudominio.com.br
# AllowedOrigins__1=https://www.seudominio.com.br
AllowedOrigins__0=https://seudominio.com.br

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
