@page "/not-found"
@layout MainLayout

<div class="not-found-container" style="text-align: center; padding: 4rem 2rem;">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="@Size.Large" Color="@Color.Warning" />
    <h3 style="margin-top: 1.5rem;">Página não encontrada</h3>
    <p style="color: #888; margin-top: 0.5rem;">
        Desculpe, o conteúdo que você está procurando não existe ou foi removido.
    </p>
    <MudButton Variant="@Variant.Filled" Color="@Color.Primary"
               href="/" style="margin-top: 1.5rem;">
        Voltar para o início
    </MudButton>
</div>
