@page "/cupons"
@using TicketPrime.Web.Services
@using TicketPrime.Web.Models
@inject CupomService CupomService
@inject SessionService Session
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Cupons - TicketPrime</PageTitle>

<style>
    .cp-wrapper {
        min-height: 100vh;
        background: var(--tp-bg-page);
        padding: 2rem;
    }

    .cp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .cp-header-left h2 {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--tp-text-heading);
        margin: 0 0 0.2rem 0;
    }

    .cp-header-left p {
        font-size: 0.875rem;
        color: var(--tp-text-muted);
        margin: 0;
    }

    .cp-btn-new {
        padding: 0.65rem 1.4rem;
        background: var(--tp-primary);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: background 0.2s, transform 0.15s;
    }

    .cp-btn-new:hover { background: var(--tp-primary-hover); transform: translateY(-1px); color: white; }

    .cp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.2rem;
    }

    .cp-card {
        background: var(--tp-bg-card);
        border-radius: 18px;
        padding: 1.5rem;
        border: 1.5px solid var(--tp-border-card);
        box-shadow: var(--tp-shadow-sm);
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
    }

    .cp-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--tp-primary), #7C7CE8);
        border-radius: 18px 18px 0 0;
    }

    .cp-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px color-mix(in srgb, var(--tp-primary) 10%, transparent);
    }

    .cp-card-code {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--tp-primary);
        letter-spacing: 1px;
        margin-bottom: 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .cp-card-code-icon {
        width: 36px; height: 36px;
        background: color-mix(in srgb, var(--tp-primary) 10%, transparent);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cp-card-code-icon svg { width: 18px; height: 18px; stroke: var(--tp-primary); }

    .cp-card-rows {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.2rem;
    }

    .cp-card-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.875rem;
    }

    .cp-card-row-label { color: var(--tp-text-muted); }

    .cp-card-row-value {
        font-weight: 600;
        color: var(--tp-text-heading);
    }

    .cp-discount-big {
        font-size: 1.8rem;
        font-weight: 800;
        color: #10B981;
    }

    .cp-tag {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-left: 0.4rem;
    }

    .cp-tag-percent { background: var(--tp-success-bg); color: var(--tp-success-text); }
    .cp-tag-fixed   { background: #DBEAFE; color: #1E40AF; }
    .cp-tag-category { background: #FEF3C7; color: #92400E; }
    .cp-tag-first   { background: #FCE7F3; color: #9D174D; }

    .cp-btn-delete {
        width: 100%;
        padding: 0.6rem;
        background: var(--tp-error-bg);
        color: #DC2626;
        border: none;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
    }

    .cp-btn-delete:hover { background: #FECACA; }

    .cp-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--tp-text-light);
    }

    .cp-empty svg { width: 48px; height: 48px; margin-bottom: 1rem; }
    .cp-empty h3 { font-size: 1.1rem; font-weight: 600; color: var(--tp-text-body); margin-bottom: 0.4rem; }

    .cp-loading {
        text-align: center;
        padding: 4rem;
        color: var(--tp-text-muted);
    }

    .cp-spinner {
        width: 36px; height: 36px;
        border: 3px solid var(--tp-border);
        border-top-color: var(--tp-primary);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    [data-theme="dark"] .cp-tag-fixed {
        background: #1E2A4A;
        color: #93C5FD;
    }
    [data-theme="dark"] .cp-tag-category {
        background: #3B3520;
        color: #FDE68A;
    }
    [data-theme="dark"] .cp-tag-first {
        background: #3B1A2E;
        color: #F9A8D4;
    }
    [data-theme="dark"] .cp-btn-delete:hover {
        background: #FECACA;
    }
    [data-theme="dark"] .cp-discount-big {
        color: #34D399;
    }
</style>

<div class="cp-wrapper">
    <div class="cp-header">
        <div class="cp-header-left">
            <h2>Cupons de desconto</h2>
            <p>Gerencie os cupons disponíveis na plataforma</p>
        </div>
        @if (Session.EhAdmin)
        {
            <a href="/cupons/cadastrar" class="cp-btn-new">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" aria-hidden="true" focusable="false">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Novo Cupom
            </a>
        }
    </div>

    @if (cupons == null)
    {
        <div class="cp-loading">
            <div class="cp-spinner"></div>
            <p>Carregando cupons...</p>
        </div>
    }
    else if (!cupons.Any())
    {
        <div class="cp-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" focusable="false">
                <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/>
            </svg>
            <h3>Nenhum cupom disponível</h3>
            <p>Os cupons cadastrados aparecerão aqui.</p>
        </div>
    }
    else
    {
        <div class="cp-grid">
            @foreach (var cupom in cupons)
            {
                <div class="cp-card">
                    <div class="cp-card-code">
                        <div class="cp-card-code-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/>
                            </svg>
                        </div>
                        @cupom.Codigo
                    </div>

                    <div class="cp-card-rows">
                        @if (cupom.TipoDesconto == 0)
                        {
                            <div class="cp-card-row">
                                <span class="cp-card-row-label">Desconto</span>
                                <span>
                                    <span class="cp-discount-big">@cupom.PorcentagemDesconto%</span>
                                    <span class="cp-tag cp-tag-percent">Percentual</span>
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="cp-card-row">
                                <span class="cp-card-row-label">Desconto</span>
                                <span>
                                    <span class="cp-discount-big">R$ @cupom.ValorDescontoFixo?.ToString("N2")</span>
                                    <span class="cp-tag cp-tag-fixed">Valor Fixo</span>
                                </span>
                            </div>
                        }
                        <div class="cp-card-row">
                            <span class="cp-card-row-label">Valor mínimo</span>
                            <span class="cp-card-row-value">R$ @cupom.ValorMinimoRegra.ToString("N2")</span>
                        </div>
                        <div class="cp-card-row">
                            <span class="cp-card-row-label">Usos</span>
                            <span class="cp-card-row-value">@cupom.TotalUsado / @(cupom.LimiteUsos == 0 ? "∞" : cupom.LimiteUsos.ToString())</span>
                        </div>
                        @if (!string.IsNullOrEmpty(cupom.CategoriaEvento))
                        {
                            <div class="cp-card-row">
                                <span class="cp-card-row-label">Categoria</span>
                                <span class="cp-card-row-value">
                                    @cupom.CategoriaEvento
                                    <span class="cp-tag cp-tag-category">Filtro</span>
                                </span>
                            </div>
                        }
                        @if (cupom.PrimeiroAcesso)
                        {
                            <div class="cp-card-row">
                                <span class="cp-card-row-label">Restrição</span>
                                <span class="cp-card-row-value">
                                    Primeira compra
                                    <span class="cp-tag cp-tag-first">Primeiro Acesso</span>
                                </span>
                            </div>
                        }
                        @if (cupom.DataExpiracao.HasValue)
                        {
                            <div class="cp-card-row">
                                <span class="cp-card-row-label">Expira em</span>
                                <span class="cp-card-row-value">@cupom.DataExpiracao.Value.ToString("dd/MM/yyyy")</span>
                            </div>
                        }
                    </div>

                    @if (Session.EhAdmin)
                    {
                        <button class="cp-btn-delete" @onclick="() => ConfirmarExclusao(cupom.Codigo)">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
                            </svg>
                            Excluir cupom
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Coupon>? cupons;

    protected override async Task OnInitializedAsync() => await CarregarCupons();

    private async Task CarregarCupons()
    {
        try { cupons = (await CupomService.ListarAsync()).ToList(); }
        catch { }
    }

    private async Task ConfirmarExclusao(string codigo)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", $"Excluir o cupom {codigo}?");
        if (confirmado) await Deletar(codigo);
    }

    private async Task Deletar(string codigo)
    {
        try
        {
            var removido = await CupomService.DeletarAsync(codigo);
            if (removido) { cupons?.RemoveAll(c => c.Codigo == codigo); StateHasChanged(); }
            else await JS.InvokeVoidAsync("alert", "Cupom não encontrado.");
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"Erro: {ex.Message}"); }
    }
}
