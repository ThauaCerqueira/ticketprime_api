@page "/recuperar-senha"
@using System.Net.Http.Json
@using TicketPrime.Web.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<style>
    .recovery-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #dde1f5 0%, #f5d6e8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .recovery-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 2.5rem 2.5rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 8px 40px rgba(99, 102, 241, 0.10);
    }

    .recovery-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .recovery-logo-icon {
        width: 56px;
        height: 56px;
        background: #5B5BD6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.6rem;
    }

    .recovery-logo-icon svg {
        width: 28px;
        height: 28px;
        fill: white;
    }

    .recovery-logo-name {
        font-size: 1.3rem;
        font-weight: 600;
        color: #5B5BD6;
        letter-spacing: -0.3px;
    }

    .recovery-title {
        text-align: center;
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .recovery-subtitle {
        text-align: center;
        font-size: 0.875rem;
        color: #6B7280;
        margin-bottom: 1.8rem;
        line-height: 1.4;
    }

    .recovery-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: 0.4rem;
        display: block;
    }

    .recovery-input-wrapper {
        position: relative;
        margin-bottom: 1.2rem;
    }

    .recovery-input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        width: 18px;
        height: 18px;
    }

    .recovery-input {
        width: 100%;
        padding: 0.7rem 1rem 0.7rem 2.6rem;
        border: 1.5px solid #E5E7EB;
        border-radius: 10px;
        font-size: 0.95rem;
        color: #374151;
        background: #fff;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    .recovery-input:focus {
        border-color: #5B5BD6;
    }

    .recovery-input::placeholder {
        color: #9CA3AF;
    }

    .recovery-btn {
        width: 100%;
        padding: 0.85rem;
        background: #5B5BD6;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        margin-bottom: 1.2rem;
    }

    .recovery-btn:hover {
        background: #4949c4;
    }

    .recovery-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .recovery-success {
        background: #D1FAE5;
        color: #065F46;
        border-radius: 8px;
        padding: 0.8rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
        text-align: center;
        line-height: 1.4;
    }

    .recovery-error {
        background: #FEE2E2;
        color: #DC2626;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
        text-align: center;
    }

    .recovery-back {
        text-align: center;
        font-size: 0.875rem;
        color: #6B7280;
    }

    .recovery-back a {
        color: #5B5BD6;
        text-decoration: none;
        font-weight: 500;
    }

    .recovery-info-box {
        background: #EFF6FF;
        border: 1px solid #BFDBFE;
        border-radius: 8px;
        padding: 0.8rem 1rem;
        font-size: 0.8rem;
        color: #1E40AF;
        margin-bottom: 1.2rem;
        text-align: center;
        line-height: 1.4;
    }
</style>

<div class="recovery-wrapper">
    <div class="recovery-card">

        <div class="recovery-logo">
            <div class="recovery-logo-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Logotipo TicketPrime">
                    <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4zM12 17.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                </svg>
            </div>
            <span class="recovery-logo-name">TicketPrime</span>
        </div>

        <div class="recovery-title">Recuperar senha</div>
        <div class="recovery-subtitle">
            Digite seu email cadastrado e enviaremos um código para redefinir sua senha.
        </div>

        @if (!string.IsNullOrEmpty(mensagemSucesso))
        {
            <div class="recovery-success">
                @mensagemSucesso
                <br /><br />
                <a href="/redefinir-senha" style="color: #065F46; font-weight: 600;">Clique aqui para redefinir a senha</a>
            </div>
        }

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="recovery-error">@erro</div>
        }

        <div class="recovery-info-box">
            📧 O código será enviado para o email cadastrado. Verifique também a caixa de spam.
        </div>

        <label class="recovery-label">Email</label>
        <div class="recovery-input-wrapper">
            <svg class="recovery-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M22 4L12 13 2 4"/>
            </svg>
            <input class="recovery-input" type="email" @bind="email" placeholder="seu@email.com" />
        </div>

        <button class="recovery-btn" @onclick="HandleSolicitar" disabled="@carregando">
            @if (carregando)
            {
                <span>Enviando...</span>
            }
            else
            {
                <span>Enviar código de redefinição</span>
            }
        </button>

        <div class="recovery-back">
            <a href="/login">Voltar para o login</a>
        </div>

    </div>
</div>

@code {
    private string email = "";
    private string erro = "";
    private string mensagemSucesso = "";
    private bool carregando = false;

    private async Task HandleSolicitar()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            erro = "Informe seu email.";
            return;
        }

        carregando = true;
        erro = "";
        mensagemSucesso = "";

        try
        {
            var dto = new PasswordResetRequest { Email = email.Trim() };
            var response = await Http.PostAsJsonAsync("api/auth/solicitar-redefinicao-senha", dto);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                mensagemSucesso = result?.Mensagem ?? "Se o email existir, um código de redefinição será enviado.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
            {
                erro = "Muitas tentativas. Aguarde um minuto e tente novamente.";
            }
            else
            {
                var errorBody = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                erro = errorBody?.Mensagem ?? "Erro ao solicitar redefinição de senha.";
            }
        }
        catch (Exception ex)
        {
            erro = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }
}
