@page "/cadastro-user"
@using System.Net.Http.Json
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-4">
    <h3>Cadastro de Usuário</h3>

    <EditForm Model="@novoUsuario" OnValidSubmit="@HandleRegistration">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="mb-3">
            <label class="form-label">CPF:</label>
            <InputText @bind-Value="novoUsuario.Cpf" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nome:</label>
            <InputText @bind-Value="novoUsuario.Nome" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email:</label>
            <InputText @bind-Value="novoUsuario.Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Senha:</label>
            <InputText @bind-Value="novoUsuario.Senha" type="password" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Cadastrar</button>
    </EditForm>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert @(mensagem.Contains("sucesso") ? "alert-success" : "alert-danger") mt-3">
            @mensagem
        </div>
    }
</div>

@code {
    private Usuario novoUsuario = new();
    private string mensagem = "";

    private async Task HandleRegistration()
    {
        try 
        {
            mensagem = "Processando...";
            var response = await Http.PostAsJsonAsync("api/usuarios", novoUsuario);

            if (response.IsSuccessStatusCode)
            {
                mensagem = "Usuário cadastrado com sucesso!";
                novoUsuario = new Usuario(); // Reseta o objeto para limpar os campos
            }
            else
            {
                // Tenta ler o erro detalhado da API se houver
                var erroDetalhado = await response.Content.ReadAsStringAsync();
                mensagem = $"Erro ao cadastrar: {erroDetalhado}";
            }
        }
        catch (Exception ex)
        {
            mensagem = $"Erro de conexão: {ex.Message}";
        }
    }
}