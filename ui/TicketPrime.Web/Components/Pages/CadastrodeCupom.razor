@page "/cupons/cadastrar"
@using src.DTOs
@using src.Service
@rendermode InteractiveServer
@inject CupomService CupomService
@inject NavigationManager Navigation

<PageTitle>Novo Cupom</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Cadastrar Novo Cupom</h3>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="alert alert-danger">@mensagemErro</div>
            }

            <EditForm Model="@novoCupom" OnValidSubmit="HandleSubmit" FormName="formCadastroCupom">
                <DataAnnotationsValidator />
                
                <div class="mb-3">
                    <label class="form-label">Código do Cupom</label>
                    <InputText @bind-Value="novoCupom.Codigo" class="form-control" placeholder="Ex: TICKET10" />
                    <ValidationMessage For="@(() => novoCupom.Codigo)" class="text-danger" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Porcentagem de Desconto (%)</label>
                        <InputNumber @bind-Value="novoCupom.PorcentagemDesconto" class="form-control" />
                        <ValidationMessage For="@(() => novoCupom.PorcentagemDesconto)" class="text-danger" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Valor Mínimo da Regra (R$)</label>
                        <InputNumber @bind-Value="novoCupom.ValorMinimoRegra" class="form-control" />
                        <ValidationMessage For="@(() => novoCupom.ValorMinimoRegra)" class="text-danger" />
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="/cupons" class="btn btn-outline-secondary">Voltar</a>
                    <button type="submit" class="btn btn-success px-5" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm"></span> <span>Salvando...</span>
                        }
                        else
                        {
                            <span>Salvar Cupom</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public CriarCupomDTO novoCupom { get; set; } = default!;

    protected override void OnInitialized()
    {
        novoCupom ??= new() { Codigo = "" };
    }
    
    private string? mensagemErro;
    private bool isSubmitting = false;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        mensagemErro = null;

        try
        {
            var sucesso = await CupomService.CriarAsync(novoCupom);

            if (sucesso)
            {
                Navigation.NavigateTo("/cupons");
            }
            else
            {
                mensagemErro = "Erro desconhecido ao salvar o cupom.";
            }
        }
        catch (Exception ex)
        {
            mensagemErro = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}