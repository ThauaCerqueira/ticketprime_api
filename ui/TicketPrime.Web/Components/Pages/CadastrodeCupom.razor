@page "/cupons/cadastrar"
@using TicketPrime.Web.Services
@using TicketPrime.Web.Models
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Navigation

<PageTitle>Criar Cupom - TicketPrime</PageTitle>

@if (!Session.EhAdmin)
{
    Navigation.NavigateTo("/", forceLoad: true);
    return;
}

<style>
    .cc-wrapper {
        min-height: 100vh;
        background: var(--tp-bg-page);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .cc-header {
        text-align: center;
        margin-bottom: 2rem;
        width: 100%;
        max-width: 540px;
    }

    .cc-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--tp-text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 1rem;
        transition: color 0.2s;
    }

    .cc-back-btn:hover { color: var(--tp-primary); }
    .cc-back-btn svg { width: 15px; height: 15px; }

    .cc-header h2 {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--tp-text-heading);
        margin: 0 0 0.4rem 0;
    }

    .cc-header p {
        font-size: 0.9rem;
        color: var(--tp-text-muted);
        margin: 0;
    }

    .cc-card {
        background: var(--tp-bg-card);
        border-radius: 18px;
        border: 1.5px solid var(--tp-border-card);
        box-shadow: var(--tp-shadow-sm);
        max-width: 540px;
        overflow: hidden;
    }

    .cc-card-header {
        padding: 1.4rem 1.8rem;
        border-bottom: 1.5px solid var(--tp-border-card);
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .cc-card-header-icon {
        width: 38px; height: 38px;
        background: var(--tp-primary-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .cc-card-header-icon svg { width: 18px; height: 18px; stroke: var(--tp-primary); }

    .cc-card-header-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--tp-text-heading);
    }

    .cc-card-body {
        padding: 1.8rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .cc-field {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .cc-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--tp-text-body);
    }

    .cc-hint {
        font-size: 0.78rem;
        color: var(--tp-text-light);
        margin-top: 0.2rem;
    }

    .cc-input {
        padding: 0.7rem 1rem;
        border: 1.5px solid var(--tp-border);
        border-radius: 10px;
        font-size: 0.95rem;
        color: var(--tp-text-heading);
        background: var(--tp-bg-input);
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
        width: 100%;
        text-transform: uppercase;
    }

    .cc-input:focus {
        border-color: var(--tp-primary);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--tp-primary) 10%, transparent);
    }

    .cc-input-normal {
        text-transform: none;
    }

    .cc-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .cc-divider {
        height: 1px;
        background: var(--tp-border-card);
        margin: 0.2rem 0;
    }

    .cc-alert {
        padding: 0.9rem 1.2rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .cc-alert-success { background: var(--tp-success-bg); color: var(--tp-success-text); }
    .cc-alert-error   { background: var(--tp-error-bg); color: var(--tp-error-text); }

    .cc-footer {
        padding: 1.2rem 1.8rem;
        border-top: 1.5px solid var(--tp-border-card);
        display: flex;
        justify-content: flex-end;
        gap: 0.8rem;
    }

    .cc-btn-cancel {
        padding: 0.65rem 1.4rem;
        background: transparent;
        color: var(--tp-text-muted);
        border: 1.5px solid var(--tp-border);
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s;
    }

    .cc-btn-cancel:hover { background: var(--tp-bg-input); color: var(--tp-text-body); }

    .cc-btn-save {
        padding: 0.65rem 1.8rem;
        background: var(--tp-primary);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: background 0.2s, transform 0.15s;
    }

    .cc-btn-save:hover { background: var(--tp-primary-hover); transform: translateY(-1px); }
    .cc-btn-save:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .cc-spinner {
        width: 15px; height: 15px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: white;
        border-radius: 50%;
        animation: cc-spin 0.8s linear infinite;
    }

    @@keyframes cc-spin { to { transform: rotate(360deg); } }

    .cc-type-group {
        display: flex;
        gap: 0.6rem;
    }

    .cc-type-btn {
        flex: 1;
        padding: 0.7rem 1rem;
        border: 1.5px solid var(--tp-border);
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: all 0.2s;
        background: var(--tp-bg-card);
        color: var(--tp-text-muted);
    }

    .cc-type-btn.active {
        border-color: var(--tp-primary);
        background: var(--tp-primary-light);
        color: var(--tp-primary);
    }

    .cc-type-btn:hover { border-color: var(--tp-primary); }

    .cc-checkbox-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0;
    }

    .cc-checkbox-row input[type="checkbox"] {
        width: 18px; height: 18px;
        accent-color: var(--tp-primary);
        cursor: pointer;
    }

    .cc-checkbox-row label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--tp-text-body);
        cursor: pointer;
    }

    @@media (max-width: 600px) {
        .cc-row { grid-template-columns: 1fr; }
        .cc-wrapper { padding: 1rem; }
    }
</style>

<div class="cc-wrapper">
    <div class="cc-header">
        <a href="/cupons" class="cc-back-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Voltar para cupons
        </a>
        <h2>Criar novo cupom</h2>
        <p>Configure o código e as regras de desconto</p>
    </div>

    <div class="cc-card">
        <div class="cc-card-header">
            <div class="cc-card-header-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                    <path d="M20 12V22H4V12"/>
                    <path d="M22 7H2v5h20V7z"/>
                    <path d="M12 22V7"/>
                </svg>
            </div>
            <span class="cc-card-header-title">Dados do cupom</span>
        </div>

        <EditForm Model="@novoCupom" OnValidSubmit="HandleSubmit" FormName="formCadastroCupom">
            <DataAnnotationsValidator />

            <div class="cc-card-body">

                @if (!string.IsNullOrEmpty(mensagemSucesso))
                {
                    <div class="cc-alert cc-alert-success">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        @mensagemSucesso
                    </div>
                }

                @if (!string.IsNullOrEmpty(mensagemErro))
                {
                    <div class="cc-alert cc-alert-error">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @mensagemErro
                    </div>
                }

                <div class="cc-field">
                    <label class="cc-label">Código do cupom</label>
                    <InputText @bind-Value="novoCupom.Codigo" class="cc-input" placeholder="Ex: TICKET10" />
                    <span class="cc-hint">O código será exibido em maiúsculas para os usuários</span>
                </div>

                <div class="cc-divider"></div>

                <div class="cc-field">
                    <label class="cc-label">Tipo de desconto</label>
                    <div class="cc-type-group">
                        <button type="button" class="cc-type-btn @(novoCupom.TipoDesconto == 0 ? "active" : "")"
                                @onclick="() => { novoCupom.TipoDesconto = 0; novoCupom.ValorDescontoFixo = null; }">
                            📊 Percentual (%)
                        </button>
                        <button type="button" class="cc-type-btn @(novoCupom.TipoDesconto == 1 ? "active" : "")"
                                @onclick="() => { novoCupom.TipoDesconto = 1; novoCupom.PorcentagemDesconto = 0; }">
                            💰 Valor Fixo (R$)
                        </button>
                    </div>
                </div>

                @if (novoCupom.TipoDesconto == 0)
                {
                    <div class="cc-row">
                        <div class="cc-field">
                            <label class="cc-label">Desconto (%)</label>
                            <InputNumber @bind-Value="novoCupom.PorcentagemDesconto" class="cc-input cc-input-normal" placeholder="Ex: 10" />
                            <span class="cc-hint">Entre 1 e 100%</span>
                        </div>
                        <div class="cc-field">
                            <label class="cc-label">Valor mínimo (R$)</label>
                            <InputNumber @bind-Value="novoCupom.ValorMinimoRegra" class="cc-input cc-input-normal" placeholder="Ex: 50,00" />
                            <span class="cc-hint">Preço mínimo para aplicar</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="cc-row">
                        <div class="cc-field">
                            <label class="cc-label">Desconto fixo (R$)</label>
                            <InputNumber @bind-Value="novoCupom.ValorDescontoFixo" class="cc-input cc-input-normal" placeholder="Ex: 20,00" />
                            <span class="cc-hint">Valor em reais a descontar</span>
                        </div>
                        <div class="cc-field">
                            <label class="cc-label">Valor mínimo (R$)</label>
                            <InputNumber @bind-Value="novoCupom.ValorMinimoRegra" class="cc-input cc-input-normal" placeholder="Ex: 50,00" />
                            <span class="cc-hint">Preço mínimo para aplicar</span>
                        </div>
                    </div>
                }

                <div class="cc-divider"></div>

                <div class="cc-row">
                    <div class="cc-field">
                        <label class="cc-label">Limite de usos</label>
                        <InputNumber @bind-Value="novoCupom.LimiteUsos" class="cc-input cc-input-normal" placeholder="0 = ilimitado" />
                        <span class="cc-hint">0 = sem limite</span>
                    </div>
                    <div class="cc-field">
                        <label class="cc-label">Data de expiração</label>
                        <InputDate @bind-Value="novoCupom.DataExpiracao" class="cc-input cc-input-normal" />
                        <span class="cc-hint">Deixe em branco para sem validade</span>
                    </div>
                </div>

                <div class="cc-divider"></div>

                <div class="cc-field">
                    <label class="cc-label">Categoria do evento (opcional)</label>
                    <InputText @bind-Value="novoCupom.CategoriaEvento" class="cc-input cc-input-normal" placeholder="Ex: Samba, Rock, Eletrônica" />
                    <span class="cc-hint">Se preenchido, o cupom só vale para eventos desta categoria</span>
                </div>

                <div class="cc-checkbox-row">
                    <InputCheckbox @bind-Value="novoCupom.PrimeiroAcesso" />
                    <label @onclick="() => novoCupom.PrimeiroAcesso = !novoCupom.PrimeiroAcesso">
                        ✅ Cupom de primeiro acesso (válido apenas na 1ª compra do usuário)
                    </label>
                </div>

            </div>

            <div class="cc-footer">
                <a href="/cupons" class="cc-btn-cancel">Cancelar</a>
                <button type="submit" class="cc-btn-save" disabled="@salvando">
                    @if (salvando)
                    {
                        <div class="cc-spinner"></div>
                        <span>Salvando...</span>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true" focusable="false">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Criar cupom</span>
                    }
                </button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public CreateCouponDto novoCupom { get; set; } = default!;

    private string? mensagemErro;
    private string? erroValidacao;
    private string mensagemSucesso = "";
    private bool salvando = false;

    protected override void OnInitialized()
    {
        novoCupom ??= new() { Codigo = "" };
    }

    private bool ValidarCampos()
    {
        erroValidacao = null;

        // Validar código: não vazio e apenas alfanumérico (RT-005)
        if (string.IsNullOrWhiteSpace(novoCupom.Codigo))
        {
            erroValidacao = "O código do cupom é obrigatório.";
            return false;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(novoCupom.Codigo, @"^[a-zA-Z0-9]+$"))
        {
            erroValidacao = "O código deve conter apenas letras e números.";
            return false;
        }

        // Validar conforme o tipo de desconto
        if (novoCupom.TipoDesconto == 0) // Percentual
        {
            if (novoCupom.PorcentagemDesconto < 1 || novoCupom.PorcentagemDesconto > 100)
            {
                erroValidacao = "O desconto percentual deve ser entre 1% e 100%.";
                return false;
            }
        }
        else // ValorFixo
        {
            if (novoCupom.ValorDescontoFixo is null or <= 0)
            {
                erroValidacao = "O desconto de valor fixo deve ser informado e positivo.";
                return false;
            }
        }

        // Validar valor mínimo >= 0 (RT-005)
        if (novoCupom.ValorMinimoRegra < 0)
        {
            erroValidacao = "O valor mínimo não pode ser negativo.";
            return false;
        }

        return true;
    }

    private async Task HandleSubmit()
    {
        salvando = true;
        mensagemErro = null;
        erroValidacao = null;
        mensagemSucesso = "";

        try
        {
            // Validação frontend adicional (RT-005)
            if (!ValidarCampos())
            {
                mensagemErro = erroValidacao;
                salvando = false;
                return;
            }

            var response = await Http.PostAsJsonAsync("api/cupons", novoCupom);

            if (response.IsSuccessStatusCode)
            {
                mensagemSucesso = "✅ Cupom criado com sucesso!";
                novoCupom = new() { Codigo = "" };
            }
            else
            {
                var statusCode = (int)response.StatusCode;

                // Tratamento específico por status code (RT-004)
                switch (statusCode)
                {
                    case 401:
                        mensagemErro = "❌ Não autorizado. Faça login novamente.";
                        break;
                    case 400:
                        try
                        {
                            var erro = await response.Content.ReadFromJsonAsync<ErroResponse>();
                            mensagemErro = erro?.Mensagem ?? "Dados inválidos. Verifique os campos.";
                        }
                        catch
                        {
                            mensagemErro = await response.Content.ReadAsStringAsync();
                        }
                        break;
                    case 409:
                        mensagemErro = "❌ Este código de cupom já existe.";
                        break;
                    case 500:
                        mensagemErro = "❌ Erro interno do servidor. Tente novamente mais tarde.";
                        break;
                    default:
                        mensagemErro = $"Erro ao criar cupom ({(int)response.StatusCode}).";
                        break;
                }
            }
        }
        catch (HttpRequestException)
        {
            mensagemErro = "❌ Erro de conexão com o servidor. Verifique se a API está rodando.";
        }
        catch (TaskCanceledException)
        {
            mensagemErro = "❌ A requisição excedeu o tempo limite. Tente novamente.";
        }
        catch (Exception ex)
        {
            mensagemErro = $"❌ Erro inesperado: {ex.Message}";
        }
        finally
        {
            salvando = false;
        }
    }

    private class ErroResponse
    {
        [System.Text.Json.Serialization.JsonPropertyName("mensagem")]
        public string? Mensagem { get; set; }
    }
}
