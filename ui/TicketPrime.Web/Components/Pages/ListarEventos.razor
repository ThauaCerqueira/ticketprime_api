@page "/eventos"
@using src.Models
@using TicketPrime.Web.Services
@using System.Net.Http.Json
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Eventos - TicketPrime</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Lista de Eventos</h3>
        @if (Session.EhAdmin)
        {
            <a href="/eventos/novo" class="btn btn-success">Novo Evento</a>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert @(mensagem.Contains("sucesso") ? "alert-success" : "alert-danger")">
            @mensagem
        </div>
    }

    @if (eventos == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Carregando eventos...</p>
        </div>
    }
    else if (!eventos.Any())
    {
        <div class="alert alert-warning">Nenhum evento cadastrado no momento.</div>
    }
    else
    {
        <table class="table table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Nome</th>
                    <th>Data</th>
                    <th>Vagas</th>
                    <th>Preço</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evento in eventos)
                {
                    <tr>
                        <td>@evento.Nome</td>
                        <td>@evento.DataEvento.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(evento.CapacidadeTotal > 0 ? "bg-success" : "bg-danger")">
                                @evento.CapacidadeTotal vagas
                            </span>
                        </td>
                        <td>@evento.PrecoPadrao.ToString("C")</td>
                        <td>
                            @if (!Session.EhAdmin && Session.EstaLogado && evento.CapacidadeTotal > 0)
                            {
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => Comprar(evento.Id)"
                                        disabled="@comprando">
                                    @if (comprando && eventoSelecionado == evento.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        <span>Comprar</span>
                                    }
                                </button>
                            }
                            else if (evento.CapacidadeTotal <= 0)
                            {
                                <span class="badge bg-secondary">Esgotado</span>
                            }
                            else if (!Session.EstaLogado)
                            {
                                <a href="/login" class="btn btn-sm btn-outline-primary">Login para comprar</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Evento>? eventos;
    private string mensagem = "";
    private bool comprando = false;
    private int eventoSelecionado = 0;

    protected override async Task OnInitializedAsync()
    {
        await CarregarEventos();
    }

    private async Task CarregarEventos()
    {
        try
        {
            eventos = await Http.GetFromJsonAsync<List<Evento>>("api/eventos");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Erro ao carregar eventos: {ex.Message}");
        }
    }

    private async Task Comprar(int eventoId)
    {
        if (!Session.EstaLogado)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        comprando = true;
        eventoSelecionado = eventoId;
        mensagem = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/reservas", new { EventoId = eventoId });

            if (response.IsSuccessStatusCode)
            {
                mensagem = "✅ Ingresso comprado com sucesso!";
                await CarregarEventos(); // Atualiza a lista para mostrar nova capacidade
            }
            else
            {
                var erro = await response.Content.ReadAsStringAsync();
                mensagem = $"❌ Erro: {erro}";
            }
        }
        catch (Exception ex)
        {
            mensagem = $"❌ Erro de conexão: {ex.Message}";
        }
        finally
        {
            comprando = false;
            eventoSelecionado = 0;
        }
    }
}
