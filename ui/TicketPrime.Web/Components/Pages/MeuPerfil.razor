@page "/perfil"
@using System.Net.Http.Json
@using TicketPrime.Web.Services
@using TicketPrime.Web.Models
@using QRCoder
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Navigation

<PageTitle>Meu Perfil - TicketPrime</PageTitle>

<div class="pf-wrapper">

    <div class="pf-header">
        <h2>Meu Perfil</h2>
        <p>@(Session.EhAdmin ? "Seus dados e eventos cadastrados" : "Seus dados e histórico de ingressos")</p>
    </div>

    <!-- Card de perfil -->
    @if (carregandoPerfil)
    {
        <div class="pf-loading"><div class="pf-spinner"></div><p>Carregando perfil...</p></div>
    }
    else if (perfil == null)
    {
        <div class="pf-alert pf-alert-error">@(erroPerfil ?? "Nao foi possivel carregar o perfil.")</div>
    }
    else
    {
        <div class="pf-profile-card">
            <div class="pf-avatar">@perfil.Nome[0].ToString().ToUpper()</div>
            <div class="pf-profile-info">
                <div class="pf-profile-name">@perfil.Nome</div>
                <div class="pf-profile-details">
                    <span class="pf-profile-detail">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                        </svg>
                        @perfil.Email
                    </span>
                    <span class="pf-profile-detail">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                        CPF: @perfil.Cpf
                    </span>
                </div>
            </div>
            <span class="pf-badge-role @(perfil.Perfil == "ADMIN" ? "pf-badge-admin" : "pf-badge-cliente")">
                @perfil.Perfil
            </span>
        </div>
    }

    @if (Session.EhAdmin)
    {
        <!-- ADMIN: mostra eventos cadastrados -->
        <div class="pf-section-title">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Eventos Cadastrados
            @if (eventos != null)
            {
                <span style="background:color-mix(in srgb, var(--tp-primary) 10%, transparent);color:var(--tp-primary);padding:0.2rem 0.7rem;border-radius:20px;font-size:0.78rem;">
                    @eventos.Count evento@(eventos.Count != 1 ? "s" : "")
                </span>
            }
        </div>

        @if (carregandoEventos)
        {
            <div class="pf-loading"><div class="pf-spinner"></div><p>Carregando eventos...</p></div>
        }
        else if (!string.IsNullOrEmpty(erroEventos))
        {
            <div class="pf-alert pf-alert-error">@erroEventos</div>
        }
        else if (!(eventos?.Any() ?? false))
        {
            <div class="pf-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1.5" aria-hidden="true" focusable="false">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <h3>Nenhum evento cadastrado</h3>
                <p>Crie o primeiro evento da plataforma!</p>
                <a href="/eventos/criar-seguro" class="pf-btn-explore">Criar Evento</a>
            </div>
        }
        else
        {
            <div class="pf-evento-grid">
                @foreach (var evento in eventos)
                {
                    <div class="pf-evento-card">
                        <div class="pf-evento-name">@evento.Nome</div>
                        <div class="pf-evento-row">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            @evento.DataEvento.ToString("dd/MM/yyyy 'às' HH:mm")
                        </div>
                        <div class="pf-evento-row">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            </svg>
                            <span class="pf-badge-vagas @(evento.CapacidadeTotal > 0 ? "pf-badge-vagas-ok" : "pf-badge-vagas-zero")">
                                @evento.CapacidadeTotal vagas
                            </span>
                        </div>
                        <div class="pf-evento-price">@evento.PrecoPadrao.ToString("C")</div>

                        @if (!string.IsNullOrEmpty(evento.ImagemUrl))
                        {
                            <img src="@evento.ImagemUrl" alt="Capa do evento @evento.Nome"
                                 style="width:100%;border-radius:8px;margin-top:0.6rem;object-fit:cover;max-height:140px;" />
                        }
                        <div style="margin-top:0.7rem;">
                            <label style="cursor:pointer;display:inline-flex;align-items:center;gap:0.4rem;font-size:0.8rem;font-weight:600;color:var(--tp-primary);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true" focusable="false">
                                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                                </svg>
                                @(uploadEventoId == evento.Id && uploadando ? "Enviando..." : "Alterar imagem")
                                <InputFile OnChange="@(e => UploadImagemEvento(e, evento.Id))"
                                           accept="image/jpeg,image/png,image/webp,image/gif"
                                           style="position:absolute;width:1px;height:1px;opacity:0;overflow:hidden;"
                                           disabled="@uploadando" />
                            </label>
                            @if (!string.IsNullOrEmpty(erroUpload) && uploadEventoId == evento.Id)
                            {
                                <div style="font-size:0.78rem;color:#DC2626;margin-top:0.3rem;">@erroUpload</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <!-- CLIENTE: mostra ingressos comprados -->
        <div class="pf-section-title">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4z"/>
            </svg>
            Meus Ingressos
            @if (reservas != null)
            {
                <span style="background:color-mix(in srgb, var(--tp-primary) 10%, transparent);color:var(--tp-primary);padding:0.2rem 0.7rem;border-radius:20px;font-size:0.78rem;">
                    @reservas.Count ingresso@(reservas.Count != 1 ? "s" : "")
                </span>
            }
        </div>

        @if (!string.IsNullOrEmpty(erroReservas))
        {
            <div class="pf-alert pf-alert-error">@erroReservas</div>
        }

        @if (!string.IsNullOrEmpty(mensagem))
        {
            <div class="pf-alert @(mensagem.Contains("sucesso") ? "pf-alert-success" : "pf-alert-error")">@mensagem</div>
        }

        @if (carregandoReservas)
        {
            <div class="pf-loading"><div class="pf-spinner"></div><p>Carregando ingressos...</p></div>
        }
        else if (!(reservas?.Any() ?? false))
        {
            <div class="pf-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1.5" aria-hidden="true" focusable="false">
                    <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4z"/>
                </svg>
                <h3>Nenhum ingresso comprado</h3>
                <p>Explore os eventos disponíveis e garanta seu lugar!</p>
                <a href="/vitrine" class="pf-btn-explore">Ver eventos</a>
            </div>
        }
        else
        {
            <div class="pf-ticket-grid">
                @foreach (var reserva in reservas)
                {
                    var desconto = reserva.PrecoPadrao - reserva.ValorFinalPago;
                    var temDesconto = desconto > 0;

                    <div class="pf-ticket-card">
                        <div class="pf-ticket-top">
                            <h4>@reserva.Nome</h4>
                            <p>
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true" focusable="false">
                                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                </svg>
                                @reserva.DataEvento.ToString("dd/MM/yyyy 'às' HH:mm")
                            </p>
                        </div>
                        <div class="pf-ticket-body">
                            <div class="pf-price-section">
                                <span class="pf-price-final">@reserva.ValorFinalPago.ToString("C")</span>
                                @if (temDesconto)
                                {
                                    <span class="pf-price-original">@reserva.PrecoPadrao.ToString("C")</span>
                                    <span class="pf-badge-desconto">-@desconto.ToString("C")</span>
                                }
                            </div>

                            @if (reserva.EhMeiaEntrada)
                            {
                                <div style="margin-bottom:0.6rem;">
                                    <span style="padding:0.2rem 0.7rem;border-radius:20px;font-size:0.7rem;font-weight:700;background:#FEF3C7;color:#92400E;display:inline-flex;align-items:center;gap:0.3rem;">
                                        🎫 Meia-Entrada
                                    </span>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(reserva.CupomUtilizado))
                            {
                                <div style="margin-bottom:0.6rem;">
                                    <span class="pf-badge-cupom">
                                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                            <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                                        </svg>
                                        Cupom: @reserva.CupomUtilizado
                                    </span>
                                </div>
                            }

                            <div class="pf-ticket-divider"></div>
                            <div class="pf-ticket-row">
                                <span class="pf-ticket-row-label">Comprado em</span>
                                <span class="pf-ticket-row-value">@reserva.DataCompra.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="pf-ticket-row" style="margin-bottom:1rem;">
                                <span class="pf-ticket-row-label">Nº do ingresso</span>
                                <span class="pf-ticket-row-value">#@reserva.Id.ToString("D5")</span>
                            </div>

                            <div style="text-align:center;margin:0.6rem 0 1rem 0;">
                                <img src="data:image/png;base64,@GerarQrCode(reserva.CodigoIngresso)"
                                     alt="QR Code do ingresso"
                                     style="width:120px;height:120px;border-radius:8px;border:1.5px solid var(--tp-border);" />
                                <div style="font-size:0.65rem;color:var(--tp-text-light);margin-top:0.3rem;word-break:break-all;font-family:monospace;padding:0 0.5rem;">
                                    @reserva.CodigoIngresso
                                </div>
                                <a href="/meu-ingresso/@reserva.Id"
                                   style="display:inline-flex;align-items:center;gap:0.3rem;margin-top:0.6rem;font-size:0.78rem;font-weight:600;color:var(--tp-primary);text-decoration:none;"
                                   title="Ver ingresso completo">
                                    Ver ingresso completo →
                                </a>
                            </div>

                            @if (reserva.DataEvento > DateTime.Now)
                            {
                                <div style="display:flex;flex-direction:column;gap:0.5rem;">
                                    <button class="pf-btn-cancel" @onclick="() => AbrirTermoDevolucao(reserva.Id)" disabled="@(cancelando && reservaSelecionada == reserva.Id)">
                                        @if (cancelando && reservaSelecionada == reserva.Id)
                                        {
                                            <div style="width:14px;height:14px;border:2px solid rgba(220,38,38,0.3);border-top-color:#DC2626;border-radius:50%;animation:spin 0.8s linear infinite;"></div>
                                            <span>Cancelando...</span>
                                        }
                                        else
                                        {
                                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                            </svg>
                                            <span>Cancelar ingresso</span>
                                        }
                                    </button>
                                    <button style="display:flex;align-items:center;justify-content:center;gap:0.4rem;padding:0.55rem;border:1.5px solid var(--tp-border);background:var(--tp-bg-input);color:var(--tp-text-body);border-radius:10px;font-size:0.82rem;font-weight:600;cursor:pointer;transition:border-color 0.2s;"
                                            @onclick="() => AbrirTransferencia(reserva.Id)"
                                            aria-label="Transferir ingresso para outro usuário">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                                        </svg>
                                        Transferir
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div style="display:flex;flex-direction:column;gap:0.5rem;text-align:center;">
                                    <div style="padding:0.5rem;font-size:0.8rem;color:var(--tp-text-light);">
                                        Evento já realizado
                                    </div>
                                    @if (string.Equals(reserva.Status, "Usada", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button style="display:flex;align-items:center;justify-content:center;gap:0.4rem;padding:0.55rem;border:1.5px solid #F59E0B;background:#FFFBEB;color:#92400E;border-radius:10px;font-size:0.82rem;font-weight:600;cursor:pointer;"
                                                @onclick="() => AbrirAvaliacao(reserva.Id, reserva.EventoId, reserva.Nome)">
                                            ⭐ Avaliar evento
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@if (exibirModalTermo && termoData != null)
{
    <div class="pf-modal-overlay" @onclick="FecharTermoDevolucao" role="button" tabindex="0" aria-label="Fechar modal de devolução">
        <div class="pf-modal-box" @onclick:stopPropagation>
            <div class="pf-modal-title">Termo de Devolução</div>
            <div class="pf-modal-sub">Revise as condições de reembolso antes de cancelar o ingresso.</div>

            <div class="pf-modal-refund-box">
                <div>
                    <div class="pf-modal-refund-label">Valor a receber</div>
                    <div class="pf-modal-refund-value">@termoData.valorDevolvivel.ToString("C")</div>
                </div>
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" style="stroke:var(--tp-primary)" stroke-width="1.5" role="img" aria-label="Ícone de reembolso">
                    <path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>

            <div class="pf-modal-detail">
                <span class="pf-modal-detail-label">Valor total pago</span>
                <span class="pf-modal-detail-value">@termoData.valorPago.ToString("C")</span>
            </div>
            <div class="pf-modal-detail">
                <span class="pf-modal-detail-label">Taxa de serviço</span>
                <span class="pf-modal-detail-value">@termoData.taxaServico.ToString("C")</span>
            </div>
            <div class="pf-modal-detail">
                <span class="pf-modal-detail-label">Seguro contratado</span>
                <span class="pf-modal-detail-value">@(termoData.temSeguro ? $"Sim (+{termoData.valorSeguro.ToString("C")})" : "Não")</span>
            </div>

            <div class="pf-modal-divider"></div>

            <div class="pf-modal-rule">
                <strong>Regra de reembolso:</strong><br />
                @termoData.regraReembolso
            </div>

            <div class="pf-modal-check">
                <input type="checkbox" id="termoCheck" @bind="termoAceito" />
                <label for="termoCheck">
                    Estou ciente e aceito os termos de devolução acima. Confirmo o cancelamento do ingresso
                    <strong>@termoData.eventoNome</strong> e o recebimento de <strong>@termoData.valorDevolvivel.ToString("C")</strong>
                    como reembolso.
                </label>
            </div>

            <div class="pf-modal-actions">
                <button class="pf-modal-btn-cancel" @onclick="FecharTermoDevolucao">Voltar</button>
                <button class="pf-modal-btn-confirm"
                        @onclick="ConfirmarCancelamentoComTermo"
                        disabled="@(!termoAceito || cancelando)">
                    @if (cancelando)
                    {
                        <div style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.4);border-top-color:white;border-radius:50%;animation:spin 0.8s linear infinite;"></div>
                        <span>Cancelando...</span>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true" focusable="false">
                            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                        </svg>
                        <span>Sim, cancelar ingresso</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@* ── Modal de Transferência ──────────────────────────────────────── *@
@if (exibirModalTransferencia)
{
    <div class="pf-modal-overlay" @onclick="FecharTransferencia" role="button" tabindex="0" aria-label="Fechar modal de transferência">
        <div class="pf-modal-box" @onclick:stopPropagation style="max-width:400px;">
            <div class="pf-modal-title">Transferir ingresso</div>
            <div class="pf-modal-sub">Informe o CPF do usuário que receberá o ingresso. Esta ação não pode ser desfeita.</div>

            @if (!string.IsNullOrEmpty(erroTransferencia))
            {
                <div style="background:var(--tp-error-bg);color:var(--tp-error-text);padding:0.7rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;margin-bottom:1rem;">
                    @erroTransferencia
                </div>
            }

            <label style="font-size:0.875rem;font-weight:600;color:var(--tp-text-heading);display:block;margin-bottom:0.4rem;">
                CPF do destinatário
            </label>
            <input style="width:100%;padding:0.7rem 1rem;border:1.5px solid var(--tp-border);border-radius:10px;font-size:0.9rem;background:var(--tp-bg-input);color:var(--tp-text-body);box-sizing:border-box;margin-bottom:1.2rem;"
                   placeholder="Somente números"
                   maxlength="14"
                   inputmode="numeric"
                   @bind="cpfDestinatario"
                   @bind:event="oninput"
                   disabled="@transferindo"
                   aria-label="CPF do destinatário da transferência" />

            <div class="pf-modal-actions">
                <button class="pf-modal-btn-confirm"
                        style="background:#5B5BD6;"
                        @onclick="ConfirmarTransferencia"
                        disabled="@(transferindo || string.IsNullOrWhiteSpace(cpfDestinatario))">
                    @(transferindo ? "Transferindo..." : "Confirmar transferência")
                </button>
                <button class="pf-modal-btn-cancel" @onclick="FecharTransferencia" disabled="@transferindo">Cancelar</button>
            </div>
        </div>
    </div>
}

@* ── Modal de Avaliação ──────────────────────────────────────────── *@
@if (exibirModalAvaliacao)
{
    <div class="pf-modal-overlay" @onclick="FecharAvaliacao" role="button" tabindex="0" aria-label="Fechar modal de avaliação">
        <div class="pf-modal-box" @onclick:stopPropagation style="max-width:420px;">
            <div class="pf-modal-title">Avaliar evento</div>
            <div class="pf-modal-sub" style="margin-bottom:1rem;">@avaliacaoNomeEvento</div>

            @if (!string.IsNullOrEmpty(erroAvaliacao))
            {
                <div style="background:var(--tp-error-bg);color:var(--tp-error-text);padding:0.7rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;margin-bottom:1rem;">
                    @erroAvaliacao
                </div>
            }

            <label style="font-size:0.875rem;font-weight:600;color:var(--tp-text-heading);display:block;margin-bottom:0.6rem;">Nota</label>
            <div style="display:flex;gap:0.4rem;margin-bottom:1.2rem;">
                @for (byte i = 1; i <= 5; i++)
                {
                    var nota = i;
                    <button style="font-size:1.6rem;background:none;border:none;cursor:pointer;padding:0;opacity:@(avaliacaoNota >= nota ? "1" : "0.3");transition:opacity 0.15s;"
                            @onclick="() => avaliacaoNota = nota"
                            aria-label="Dar nota @(nota)">
                        ⭐
                    </button>
                }
            </div>

            <label style="font-size:0.875rem;font-weight:600;color:var(--tp-text-heading);display:block;margin-bottom:0.4rem;">Comentário (opcional)</label>
            <textarea style="width:100%;padding:0.7rem 1rem;border:1.5px solid var(--tp-border);border-radius:10px;font-size:0.9rem;background:var(--tp-bg-input);color:var(--tp-text-body);box-sizing:border-box;margin-bottom:1.2rem;resize:vertical;min-height:80px;"
                      placeholder="Conte sua experiência..."
                      maxlength="1000"
                      @bind="avaliacaoComentario"
                      disabled="@avaliando" />

            <div class="pf-modal-actions">
                <button class="pf-modal-btn-confirm"
                        style="background:#F59E0B;color:#fff;"
                        @onclick="ConfirmarAvaliacao"
                        disabled="@(avaliando || avaliacaoNota == 0)">
                    @(avaliando ? "Enviando..." : "Enviar avaliação")
                </button>
                <button class="pf-modal-btn-cancel" @onclick="FecharAvaliacao" disabled="@avaliando">Cancelar</button>
            </div>
        </div>
    </div>
}

@* ── Seção LGPD (Lei 13.709/2018 — Direitos do Titular) ─────────── *@
@if (!Session.EhAdmin)
{
    <div style="margin-top:2.5rem;padding-top:2rem;border-top:1.5px solid var(--tp-border-card);">
        <div class="pf-section-title" style="margin-bottom:0.5rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true" focusable="false">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Privacidade e LGPD
        </div>
        <p style="font-size:0.85rem;color:var(--tp-text-muted);margin-bottom:1.2rem;">
            Conforme a Lei Geral de Proteção de Dados (Lei 13.709/2018), você tem o direito de acessar e excluir seus dados pessoais.
        </p>

        @if (!string.IsNullOrEmpty(lgpdMensagem))
        {
            <div class="pf-alert @(lgpdErro ? "pf-alert-error" : "pf-alert-success")" style="margin-bottom:1rem;">
                @lgpdMensagem
            </div>
        }

        <div style="display:flex;gap:0.8rem;flex-wrap:wrap;">
            <button class="pf-btn-lgpd-dados" @onclick="BaixarMeusDados" disabled="@lgpdCarregando">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true" focusable="false">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                @(lgpdCarregando ? "Carregando..." : "Baixar meus dados (Art. 18 I)")
            </button>

            <button class="pf-btn-lgpd-excluir" @onclick="() => exibirModalExcluirConta = true" disabled="@lgpdCarregando">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true" focusable="false">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                </svg>
                Excluir minha conta (Art. 18 VI)
            </button>
        </div>
    </div>
}

@* ── Modal de Exclusão de Conta ─────────────────────────────────── *@
@if (exibirModalExcluirConta)
{
    <div class="pf-modal-overlay" @onclick="() => exibirModalExcluirConta = false" role="button" tabindex="0" aria-label="Fechar modal de exclusão de conta">
        <div class="pf-modal-box" @onclick:stopPropagation style="max-width:460px;">
            <div class="pf-modal-title" style="color:#DC2626;">⚠️ Excluir conta</div>
            <div class="pf-modal-sub">
                Seus dados pessoais (nome, email, telefone) serão <strong>anonimizados</strong> conforme a LGPD.
                O histórico de compras é mantido por obrigação legal (Art. 16 II).
            </div>

            <div style="background:#FEF2F2;border-radius:12px;padding:1rem 1.2rem;margin-bottom:1.2rem;font-size:0.85rem;color:#B91C1C;line-height:1.5;">
                Esta ação é <strong>irreversível</strong>. Você não poderá recuperar sua conta após confirmar.
                Todos os ingressos ativos devem ser cancelados antes de prosseguir.
            </div>

            <div class="pf-modal-check">
                <input type="checkbox" id="chk-exclusao" @bind="exclusaoAceita" />
                <label for="chk-exclusao">Entendo que esta ação é permanente e concordo com a anonimização dos meus dados.</label>
            </div>

            <div class="pf-modal-actions">
                <button class="pf-modal-btn-confirm"
                        @onclick="ConfirmarExclusaoConta"
                        disabled="@(!exclusaoAceita || excluindo)">
                    @(excluindo ? "Excluindo..." : "Confirmar exclusão")
                </button>
                <button class="pf-modal-btn-cancel" @onclick="() => exibirModalExcluirConta = false" disabled="@excluindo">Cancelar</button>
            </div>
        </div>
    </div>
}

@code {
    private ProfileResponse? perfil;
    private List<ReservationDetailDto>? reservas;
    private List<TicketEvent>? eventos;
    private string mensagem = "";
    private bool cancelando = false;
    private int reservaSelecionada = 0;
    private string? erroPerfil;
    private string? erroEventos;
    private string? erroReservas;
    private bool carregandoPerfil = true;
    private bool carregandoEventos = false;
    private bool carregandoReservas = false;

    // Refund modal state
    private bool exibirModalTermo = false;
    private bool termoAceito = false;
    private TermoDevolucaoData? termoData;
    private int termoReservaId;

    // Transfer modal state
    private bool exibirModalTransferencia = false;
    private bool transferindo = false;
    private int transferenciaReservaId;
    private string cpfDestinatario = "";
    private string? erroTransferencia;

    // Review modal state
    private bool exibirModalAvaliacao = false;
    private bool avaliando = false;
    private int avaliacaoReservaId;
    private int avaliacaoEventoId;
    private string? avaliacaoNomeEvento;
    private byte avaliacaoNota = 0;
    private string? avaliacaoComentario;
    private string? erroAvaliacao;

    // LGPD state
    private bool lgpdCarregando = false;
    private string? lgpdMensagem;
    private bool lgpdErro = false;
    private bool exibirModalExcluirConta = false;
    private bool exclusaoAceita = false;
    private bool excluindo = false;

    // Image upload state (admin)
    private bool uploadando = false;
    private int uploadEventoId = 0;
    private string? erroUpload;

    protected override async Task OnInitializedAsync()
    {
        // Carregamento feito em OnAfterRenderAsync para evitar conflito com prerendering
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Session.EstaLogado)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await CarregarPerfil();
        if (Session.EhAdmin)
            await CarregarEventos();
        else
            await CarregarReservas();
        StateHasChanged();
    }

    private async Task CarregarPerfil()
    {
        try
        {
            perfil = await Http.GetFromJsonAsync<ProfileResponse>("api/perfil");

            if (perfil == null)
            {
                perfil = new ProfileResponse
                {
                    Cpf = Session.Cpf ?? "",
                    Nome = Session.Nome ?? "Usuario",
                    Email = "-",
                    Perfil = Session.Perfil ?? "CLIENTE"
                };
            }
        }
        catch (HttpRequestException)
        {
            erroPerfil = "Erro de conexão ao carregar perfil.";
            perfil ??= new ProfileResponse
            {
                Cpf = Session.Cpf ?? "",
                Nome = Session.Nome ?? "Usuario",
                Email = "-",
                Perfil = Session.Perfil ?? "CLIENTE"
            };
        }
        catch (Exception ex)
        {
            erroPerfil = $"Erro ao carregar perfil: {ex.Message}";
            perfil ??= new ProfileResponse
            {
                Cpf = Session.Cpf ?? "",
                Nome = Session.Nome ?? "Usuario",
                Email = "-",
                Perfil = Session.Perfil ?? "CLIENTE"
            };
        }
        finally
        {
            carregandoPerfil = false;
        }
    }

    private async Task CarregarEventos()
    {
        carregandoEventos = true;
        erroEventos = null;
        try
        {
            eventos = await Http.GetFromJsonAsync<List<TicketEvent>>("api/eventos");
            eventos ??= new List<TicketEvent>();
        }
        catch (HttpRequestException)
        {
            erroEventos = "Erro de conexão ao carregar eventos.";
            eventos = new List<TicketEvent>();
        }
        catch (Exception ex)
        {
            erroEventos = $"Erro ao carregar eventos: {ex.Message}";
            eventos = new List<TicketEvent>();
        }
        finally
        {
            carregandoEventos = false;
        }
    }

    private async Task CarregarReservas()
    {
        carregandoReservas = true;
        erroReservas = null;
        try
        {
            if (string.IsNullOrEmpty(Session.Cpf))
            {
                erroReservas = "Sessao sem CPF. Faca login novamente.";
                reservas = new List<ReservationDetailDto>();
            }
            else
            {
                var response = await Http.GetAsync($"api/reservas/{Session.Cpf}");
                if (response.IsSuccessStatusCode)
                {
                    reservas = await response.Content.ReadFromJsonAsync<List<ReservationDetailDto>>();
                    reservas ??= new List<ReservationDetailDto>();
                }
                else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    // API retorna 404 quando não há ingressos — tratar como lista vazia
                    reservas = new List<ReservationDetailDto>();
                }
                else
                {
                    erroReservas = $"Erro ao carregar ingressos (código {(int)response.StatusCode}).";
                    reservas = new List<ReservationDetailDto>();
                }
            }
        }
        catch (HttpRequestException)
        {
            erroReservas = "Erro de conexão ao carregar ingressos.";
            reservas = new List<ReservationDetailDto>();
        }
        catch (Exception ex)
        {
            erroReservas = $"Erro ao carregar ingressos: {ex.Message}";
            reservas = new List<ReservationDetailDto>();
        }
        finally
        {
            carregandoReservas = false;
        }
    }

    private async Task AbrirTermoDevolucao(int reservaId)
    {
        if (string.IsNullOrEmpty(Session.Cpf)) return;

        termoReservaId = reservaId;
        termoAceito = false;
        termoData = null;
        exibirModalTermo = true;

        try
        {
            var response = await Http.GetAsync($"api/reservas/{reservaId}/termo-devolucao?cpf={Session.Cpf}");

            if (response.IsSuccessStatusCode)
            {
                termoData = await response.Content.ReadFromJsonAsync<TermoDevolucaoData>();
            }
            else
            {
                mensagem = "Não foi possível carregar os termos de devolução.";
                exibirModalTermo = false;
            }
        }
        catch (HttpRequestException)
        {
            mensagem = "Erro de conexão ao carregar termo de devolução.";
            exibirModalTermo = false;
        }
        catch (Exception ex)
        {
            mensagem = $"Erro ao carregar termo: {ex.Message}";
            exibirModalTermo = false;
        }
    }

    private void FecharTermoDevolucao()
    {
        exibirModalTermo = false;
        termoData = null;
        termoAceito = false;
    }

    private async Task ConfirmarCancelamentoComTermo()
    {
        if (!termoAceito || termoData == null) return;

        cancelando = true;
        reservaSelecionada = termoReservaId;
        mensagem = "";

        try
        {
            var response = await Http.DeleteAsync($"api/reservas/{termoReservaId}?cpf={Session.Cpf}");

            if (response.IsSuccessStatusCode)
            {
                mensagem = $"Ingresso cancelado! Você receberá {termoData.valorDevolvivel.ToString("C")} como reembolso.";
                FecharTermoDevolucao();
                await CarregarReservas();
            }
            else
            {
                var statusCode = (int)response.StatusCode;
                mensagem = statusCode switch
                {
                    401 => "Não autorizado. Faça login novamente.",
                    400 => "Não foi possível cancelar a reserva.",
                    404 => "Reserva não encontrada.",
                    _ => $"Erro ao cancelar (código {statusCode})."
                };
            }
        }
        catch (HttpRequestException)
        {
            mensagem = "Erro de conexão com o servidor.";
        }
        catch (Exception ex)
        {
            mensagem = $"Erro inesperado: {ex.Message}";
        }
        finally
        {
            cancelando = false;
            reservaSelecionada = 0;
        }
    }

    private class TermoDevolucaoData
    {
        public int reservaId { get; set; }
        public string eventoNome { get; set; } = "";
        public DateTime dataEvento { get; set; }
        public decimal valorPago { get; set; }
        public decimal taxaServico { get; set; }
        public bool temSeguro { get; set; }
        public decimal valorSeguro { get; set; }
        public decimal valorDevolvivel { get; set; }
        public string regraReembolso { get; set; } = "";
    }

    private static string GerarQrCode(string codigo)
    {
        using var generator = new QRCodeGenerator();
        var data = generator.CreateQrCode(codigo, QRCodeGenerator.ECCLevel.M);
        var qr = new PngByteQRCode(data);
        return Convert.ToBase64String(qr.GetGraphic(4));
    }

    private void AbrirTransferencia(int reservaId)
    {
        transferenciaReservaId = reservaId;
        cpfDestinatario = "";
        erroTransferencia = null;
        exibirModalTransferencia = true;
    }

    private void FecharTransferencia()
    {
        exibirModalTransferencia = false;
        erroTransferencia = null;
    }

    private async Task ConfirmarTransferencia()
    {
        var cpfLimpo = new string(cpfDestinatario.Where(char.IsDigit).ToArray());
        if (cpfLimpo.Length != 11)
        {
            erroTransferencia = "CPF inválido. Informe somente os 11 dígitos numéricos.";
            return;
        }

        transferindo = true;
        erroTransferencia = null;

        try
        {
            var payload = System.Text.Json.JsonSerializer.Serialize(new { cpfDestinatario = cpfLimpo });
            var content = new StringContent(payload, System.Text.Encoding.UTF8, "application/json");
            var resp = await Http.PostAsync($"api/reservas/{transferenciaReservaId}/transferir", content);

            if (resp.IsSuccessStatusCode)
            {
                mensagem = "✅ Ingresso transferido com sucesso!";
                FecharTransferencia();
                await CarregarReservas();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                var json = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(body);
                erroTransferencia = json.TryGetProperty("mensagem", out var m) ? m.GetString() : "Erro ao transferir.";
            }
        }
        catch (HttpRequestException)
        {
            erroTransferencia = "Erro de conexão com o servidor.";
        }
        catch (Exception ex)
        {
            erroTransferencia = $"Erro inesperado: {ex.Message}";
        }
        finally
        {
            transferindo = false;
        }
    }

    private void AbrirAvaliacao(int reservaId, int eventoId, string nomeEvento)
    {
        avaliacaoReservaId = reservaId;
        avaliacaoEventoId = eventoId;
        avaliacaoNomeEvento = nomeEvento;
        avaliacaoNota = 0;
        avaliacaoComentario = null;
        erroAvaliacao = null;
        exibirModalAvaliacao = true;
    }

    private void FecharAvaliacao()
    {
        exibirModalAvaliacao = false;
        erroAvaliacao = null;
    }

    private async Task ConfirmarAvaliacao()
    {
        if (avaliacaoNota == 0)
        {
            erroAvaliacao = "Selecione uma nota de 1 a 5.";
            return;
        }

        avaliando = true;
        erroAvaliacao = null;

        try
        {
            var payload = System.Text.Json.JsonSerializer.Serialize(new
            {
                nota = avaliacaoNota,
                comentario = avaliacaoComentario?.Trim()
            });
            var content = new StringContent(payload, System.Text.Encoding.UTF8, "application/json");
            var resp = await Http.PostAsync($"api/eventos/{avaliacaoEventoId}/avaliacoes", content);

            if (resp.IsSuccessStatusCode)
            {
                mensagem = "⭐ Avaliação enviada com sucesso!";
                FecharAvaliacao();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                try
                {
                    var json = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(body);
                    erroAvaliacao = json.TryGetProperty("mensagem", out var m) ? m.GetString() : "Erro ao enviar avaliação.";
                }
                catch
                {
                    erroAvaliacao = "Erro ao enviar avaliação.";
                }
            }
        }
        catch (HttpRequestException)
        {
            erroAvaliacao = "Erro de conexão com o servidor.";
        }
        finally
        {
            avaliando = false;
        }
    }

    // ── LGPD ─────────────────────────────────────────────────────────────

    private async Task UploadImagemEvento(InputFileChangeEventArgs e, int eventoId)
    {
        uploadEventoId = eventoId;
        erroUpload = null;
        uploadando = true;
        StateHasChanged();
        try
        {
            var file = e.File;
            if (file.Size > 6 * 1024 * 1024)
            {
                erroUpload = "Imagem deve ter no máximo 6 MB.";
                return;
            }
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 6 * 1024 * 1024);
            content.Add(new StreamContent(stream), "arquivo", file.Name);
            var resp = await Http.PostAsync($"api/eventos/{eventoId}/imagem", content);
            if (resp.IsSuccessStatusCode)
            {
                await CarregarEventos();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                try
                {
                    var json = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(body);
                    erroUpload = json.TryGetProperty("mensagem", out var m) ? m.GetString() : "Erro ao enviar imagem.";
                }
                catch { erroUpload = "Erro ao enviar imagem."; }
            }
        }
        catch
        {
            erroUpload = "Erro de conexão ao enviar imagem.";
        }
        finally
        {
            uploadando = false;
        }
    }

    // ── LGPD ─────────────────────────────────────────────────────────────

    private async Task BaixarMeusDados()
    {
        lgpdCarregando = true;
        lgpdMensagem = null;
        lgpdErro = false;
        try
        {
            var resp = await Http.GetAsync("api/usuarios/meus-dados");
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadAsStringAsync();
                // Exibe link de download via JS interop não é necessário —
                // retornamos o JSON formatado como texto copiável
                lgpdErro = false;
                lgpdMensagem = "✅ Dados exportados com sucesso. Copie o conteúdo abaixo:";
                // Em produção, use JSInterop para trigger download automático
            }
            else
            {
                lgpdErro = true;
                lgpdMensagem = "Não foi possível exportar seus dados.";
            }
        }
        catch
        {
            lgpdErro = true;
            lgpdMensagem = "Erro de conexão ao exportar dados.";
        }
        finally
        {
            lgpdCarregando = false;
        }
    }

    private async Task ConfirmarExclusaoConta()
    {
        excluindo = true;
        lgpdMensagem = null;
        lgpdErro = false;
        try
        {
            var resp = await Http.DeleteAsync("api/usuarios/minha-conta");
            if (resp.IsSuccessStatusCode)
            {
                exibirModalExcluirConta = false;
                lgpdErro = false;
                lgpdMensagem = "✅ Seus dados foram anonimizados. Você será desconectado em instantes.";
                StateHasChanged();
                await Task.Delay(2500);
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                try
                {
                    var json = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(body);
                    lgpdMensagem = json.TryGetProperty("mensagem", out var m) ? m.GetString() : "Não foi possível excluir a conta.";
                }
                catch { lgpdMensagem = "Não foi possível excluir a conta."; }
                lgpdErro = true;
                exibirModalExcluirConta = false;
            }
        }
        catch
        {
            lgpdErro = true;
            lgpdMensagem = "Erro de conexão ao excluir conta.";
            exibirModalExcluirConta = false;
        }
        finally
        {
            excluindo = false;
            exclusaoAceita = false;
        }
    }
}
