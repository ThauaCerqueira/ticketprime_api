@inherits LayoutComponentBase
@inject TicketPrime.Web.Services.SessionService Session
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable
<div class="app-layout">
    <NavMenu />
    <main class="app-main">
        @Body
    </main>
</div>

@* ═══════════════════════════════════════════════════════════════
   Banner de saúde da API — exibe aviso amigável quando o backend
   está offline, em vez de erros de conexão sem contexto.
   ═══════════════════════════════════════════════════════════════ *@
<ApiHealthBanner />

<!-- Provedores MudBlazor: necessários para Snackbar, Popover e Dialog em toda a aplicação -->
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.CarregarAsync();
            await InitThemeAsync();
            GuardarSenhaTemporaria();
            Session.OnChange += OnSessionChanged;
        }
    }

    private void GuardarSenhaTemporaria()
    {
        if (Session.DeveTrocarSenha && Session.EstaLogado)
        {
            var uri = new Uri(Navigation.Uri);
            if (!uri.AbsolutePath.Equals("/trocar-senha", StringComparison.OrdinalIgnoreCase))
                Navigation.NavigateTo("/trocar-senha");
        }
    }

    private void OnSessionChanged()
    {
        GuardarSenhaTemporaria();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.OnChange -= OnSessionChanged;
    }

    private async Task InitThemeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("ticketPrimeTheme.initTheme");
        }
        catch
        {
            // JS interop pode falhar durante pré-renderização — ignorar
        }
    }
}

