@using TicketPrime.Web.Services
@inject HealthCheckService HealthCheck

@if (!_saudavel && _mostrar)
{
    <div class="api-health-banner" role="alert">
        <div class="api-health-banner-content">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>
                <strong>Servidor temporariamente indisponível</strong> — @_mensagem
                <button class="api-health-banner-retry" @onclick="VerificarAgora" aria-label="Tentar conectar novamente">
                    Tentar novamente
                </button>
            </span>
        </div>
        <button class="api-health-banner-close" @onclick="() => _mostrar = false" aria-label="Fechar aviso">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
}

@code {
    private bool _saudavel = true;
    private bool _mostrar = true;
    private string _mensagem = "";

    protected override void OnInitialized()
    {
        HealthCheck.OnStatusChanged += (saudavel, mensagem) =>
        {
            _saudavel = saudavel;
            _mensagem = mensagem ?? "";
            if (saudavel) _mostrar = true; // Reexibe se reconectar
            InvokeAsync(StateHasChanged);
        };
    }

    private async Task VerificarAgora()
    {
        // Força uma verificação imediata
        _mensagem = "Verificando...";
        // O HealthCheckService já tem timer, mas podemos forçar
        // apenas aguardar o próximo ciclo
        await Task.Delay(100);
    }
}

<style>
    .api-health-banner {
        background: #FEF3C7;
        border-bottom: 1px solid #F59E0B;
        padding: 0.5rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: #92400E;
        animation: slideDown 0.3s ease-out;
    }

    .api-health-banner-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex: 1;
    }

    .api-health-banner-retry {
        background: #F59E0B;
        color: white;
        border: none;
        padding: 0.15rem 0.6rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 600;
        margin-left: 0.5rem;
        transition: background 0.2s;
    }

    .api-health-banner-retry:hover {
        background: #D97706;
    }

    .api-health-banner-close {
        background: none;
        border: none;
        cursor: pointer;
        color: #92400E;
        padding: 0.25rem;
        display: flex;
        align-items: center;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .api-health-banner-close:hover {
        opacity: 1;
    }

    @@keyframes slideDown {
        from { transform: translateY(-100%); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>
