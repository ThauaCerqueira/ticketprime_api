@using System.Net.Http.Json
@using System.Text.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Configuration
@using QRCoder
@using TicketPrime.Web.Services
@using TicketPrime.Web.Models
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject ILogger<CompraModal> Logger

@if (Visible && Evento != null)
{
    <div class="vitrine-overlay" @onclick="FecharModal" role="button" tabindex="0" aria-label="Fechar modal de compra">
        <div class="vitrine-modal" @onclick:stopPropagation>
            @if (compraSucesso)
            {
                <div class="vitrine-modal-success">
                    <div class="vitrine-modal-success-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#065F46" stroke-width="2.5" aria-hidden="true" focusable="false">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <h4>Ingresso comprado! 🎫</h4>
                    <p>Seu ingresso para <strong>@Evento.Nome</strong> foi confirmado.</p>

                    @* ── PIX QR Code ──────────────────────────────────────────── *@
                    @if (!string.IsNullOrEmpty(pixChavePix))
                    {
                        <div style="margin-top:1.2rem;padding:1rem;background:var(--tp-bg-page);border-radius:14px;border:1.5px solid var(--tp-border-card);">
                            <div style="font-size:0.9rem;font-weight:700;color:var(--tp-text-heading);margin-bottom:0.6rem;text-align:center;">
                                💠 Pagamento PIX
                            </div>
                            <div style="font-size:0.78rem;color:var(--tp-text-muted);text-align:center;margin-bottom:0.8rem;">
                                Escaneie o QR Code abaixo ou copie a chave PIX para pagar.
                            </div>

                            @* QR Code Image *@
                            @if (!string.IsNullOrEmpty(pixQrCodeBase64))
                            {
                                <div style="display:flex;justify-content:center;margin-bottom:0.8rem;">
                                    <img src="data:image/png;base64,@pixQrCodeBase64"
                                         alt="QR Code PIX"
                                         style="width:220px;height:220px;border-radius:12px;border:2px solid var(--tp-border-card);"
                                         title="Escaneie este QR Code para pagar" />
                                </div>
                            }

                            @* Copia e Cola *@
                            <div style="background:var(--tp-bg-input);border-radius:10px;padding:0.6rem 0.8rem;word-break:break-all;font-size:0.75rem;font-family:monospace;color:var(--tp-text-body);margin-bottom:0.6rem;user-select:all;">
                                @pixChavePix
                            </div>

                            <button class="vitrine-modal-btn-secondary"
                                    @onclick="CopiarChavePix"
                                    style="font-size:0.82rem;padding:0.4rem 1rem;width:100%;"
                                    aria-label="Copiar chave PIX">
                                📋 Copiar chave PIX
                            </button>
                        </div>
                    }

                    <button class="vitrine-modal-btn-primary" @onclick="FecharModal" aria-label="Ir para meus ingressos" style="margin-top:1rem;">
                        Ver meus ingressos
                    </button>
                </div>
            }
            else
            {
                <h3>Confirmar compra</h3>
                <div class="vitrine-modal-sub">Revise os detalhes antes de confirmar.</div>

                @if (!string.IsNullOrEmpty(erroCompra))
                {
                    <div class="vitrine-modal-error">@erroCompra</div>
                }

                <div class="vitrine-modal-row">
                    <span class="vitrine-modal-row-label">Evento</span>
                    <span class="vitrine-modal-row-value">@Evento.Nome</span>
                </div>
                <div class="vitrine-modal-row">
                    <span class="vitrine-modal-row-label">Data</span>
                    <span class="vitrine-modal-row-value">@Evento.DataEvento.ToString("dd/MM/yyyy HH:mm")</span>
                </div>

                @* Seletor de setor / tipo de ingresso *@
                @if (tiposIngressoEvento != null && tiposIngressoEvento.Count > 0)
                {
                    <div class="vitrine-modal-divider"></div>
                    <div style="margin:0.6rem 0;">
                        <label style="font-size:0.875rem;font-weight:600;color:#374151;display:block;margin-bottom:0.4rem;">Setor / Tipo de ingresso *</label>
                        <select class="vitrine-modal-input" @bind="_selectedTicketType">
                            @foreach (var ti in tiposIngressoEvento.OrderBy(t => t.Ordem))
                            {
                                <option value="@ti.Id">
                                    @ti.Nome – @ti.Preco.ToString("C") (@ti.CapacidadeRestante vagas)
                                </option>
                            }
                        </select>
                    </div>
                }

                @if (Evento.TemMeiaEntrada)
                {
                    <div class="vitrine-modal-divider"></div>
                    <div style="display:flex;gap:0.8rem;margin:0.6rem 0;">
                        <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-size:0.9rem;font-weight:500;color:var(--tp-text-heading);">
                            <input type="radio" name="tipoIngresso"
                                   checked="@(!ehMeiaEntrada)"
                                   @onclick="() => { ehMeiaEntrada = false; RemoverDocumento(); }"
                                   style="accent-color:var(--tp-primary);width:16px;height:16px;cursor:pointer;" />
                            Inteira
                            <span style="font-weight:700;color:var(--tp-primary);">@PrecoBase.ToString("C")</span>
                        </label>
                        <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-size:0.9rem;font-weight:500;color:var(--tp-text-heading);">
                            <input type="radio" name="tipoIngresso"
                                   checked="@ehMeiaEntrada"
                                   @onclick="() => ehMeiaEntrada = true"
                                   style="accent-color:var(--tp-primary);width:16px;height:16px;cursor:pointer;" />
                            Meia-entrada
                            <span style="font-weight:700;color:var(--tp-success-text);">@((PrecoBase / 2).ToString("C"))</span>
                        </label>
                    </div>

                    @* Upload de documento comprobatório - Lei 12.933/2013 *@
                    @if (ehMeiaEntrada)
                    {
                        <div style="margin:0.6rem 0;padding:0.8rem;background:#FFF7ED;border:1.5px dashed #F97316;border-radius:8px;">
                            <label style="display:block;font-size:0.82rem;font-weight:600;color:#9A3412;margin-bottom:0.4rem;">
                                📄 Documento comprobatório (obrigatório)
                            </label>
                            <p style="font-size:0.75rem;color:#C2410C;margin:0 0 0.5rem 0;line-height:1.4;">
                                Envie sua carteirinha estudantil, identidade de idoso (60+), laudo médico ou outro documento que comprove sua elegibilidade à meia-entrada, conforme Lei 12.933/2013.
                                <br /><strong>Formatos aceitos:</strong> JPEG, PNG, WebP, PDF (máx. 10 MB).
                            </p>
                            <InputFile accept=".jpg,.jpeg,.png,.webp,.pdf"
                                       style="display:block;width:100%;font-size:0.82rem;padding:0.3rem 0;cursor:pointer;"
                                       OnChange="OnDocumentoSelecionado"
                                       disabled="@(comprando)" />
                            @if (!string.IsNullOrEmpty(nomeDocumento))
                            {
                                <div style="display:flex;align-items:center;gap:0.4rem;margin-top:0.4rem;font-size:0.78rem;color:#059669;">
                                    <span>✅</span>
                                    <span>@nomeDocumento</span>
                                    <span style="color:#6B7280;">(@tamanhoDocumento)</span>
                                    <button type="button"
                                            style="margin-left:auto;background:none;border:none;color:#DC2626;cursor:pointer;font-size:0.78rem;text-decoration:underline;padding:0;"
                                            @onclick="RemoverDocumento"
                                            aria-label="Remover documento">
                                        Remover
                                    </button>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(erroDocumento))
                            {
                                <div style="margin-top:0.3rem;font-size:0.78rem;color:#DC2626;">@erroDocumento</div>
                            }
                        </div>
                    }
                }

                <div class="vitrine-modal-divider"></div>

                <label style="font-size:0.875rem;font-weight:600;color:#374151;">
                    Cupom de desconto (opcional)
                </label>
                <input class="vitrine-modal-input"
                       placeholder="Ex: PRIME10"
                       @bind="cupomDigitado"
                       @bind:event="oninput"
                       disabled="@(comprando)" />

                <div style="display:flex;align-items:flex-start;gap:0.6rem;margin:0.4rem 0 0.8rem 0;">
                    <input type="checkbox" id="chkSeguro"
                           style="margin-top:3px;width:16px;height:16px;accent-color:#5B5BD6;cursor:pointer;flex-shrink:0;"
                           @bind="contratarSeguro" disabled="@(comprando)" />
                    <label for="chkSeguro" style="font-size:0.875rem;color:#374151;cursor:pointer;line-height:1.4;">
                        Seguro de Devolução <strong style="color:#5B5BD6;">+@((PrecoBase * 0.15m).ToString("C"))</strong><br />
                        <span style="font-size:0.78rem;color:#6B7280;">Reembolso integral se você cancelar o ingresso.</span>
                    </label>
                </div>

                <div class="vitrine-modal-divider"></div>

                @* ── Forma de pagamento ──────────────────────────────────── *@
                <div style="margin:0.4rem 0 0.8rem 0;">
                    <div style="font-size:0.875rem;font-weight:600;color:var(--tp-text-heading);margin-bottom:0.5rem;">Forma de pagamento</div>
                    <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
                        @foreach (var (valor, rotulo, icone) in new[] {
                            ("pix","Pix","💠"),
                            ("cartao_credito","Crédito","💳"),
                            ("cartao_debito","Débito","💳")
                        })
                        {
                            var ativo = metodoPagamento == valor;
                            <button type="button"
                                    style="padding:0.45rem 0.85rem;border-radius:8px;font-size:0.82rem;font-weight:600;cursor:pointer;border:1.5px solid @(ativo ? "var(--tp-primary)" : "var(--tp-border)");background:@(ativo ? "var(--tp-primary)" : "var(--tp-bg-input)");color:@(ativo ? "white" : "var(--tp-text-body)");transition:all 0.15s;"
                                    @onclick="() => OnMetodoPagamentoChanged(valor)"
                                    disabled="@(comprando)"
                                    aria-pressed="@ativo"
                                    aria-label="Pagar com @rotulo">
                                @icone @rotulo
                            </button>
                        }
                    </div>
                    @if (metodoPagamento is "cartao_credito" or "cartao_debito")
                    {
                        <div style="margin-top:0.8rem;">
                            @* ── Nome do titular (campo nativo — não sensível) ──────────── *@
                            <input class="vitrine-modal-input"
                                   style="margin:0 0 0.6rem 0;"
                                   placeholder="Nome no cartão"
                                   maxlength="60"
                                   @bind="nomeTitular"
                                   @bind:event="oninput"
                                   disabled="@(comprando || cardTokenizing)"
                                   aria-label="Nome do titular do cartão" />

                            @* ── Campos sensíveis do cartão (renderizados via iframes do MP) ── *@
                            <div style="font-size:0.78rem;font-weight:600;color:#6B7280;margin-bottom:0.3rem;">
                                Dados do cartão (criptografados pelo Mercado Pago)
                            </div>
                            <div id="mp-card-fields-container"
                                 style="display:flex;flex-direction:column;gap:0.5rem;">
                                @* Card Number *@
                                <div>
                                    <div id="mp-cardNumber" class="mp-field-wrapper"></div>
                                </div>
                                @* Expiry + CVV side by side *@
                                <div style="display:flex;gap:0.5rem;">
                                    <div style="flex:1;">
                                        <div id="mp-cardExpirationMonth" class="mp-field-wrapper"></div>
                                    </div>
                                    <div style="flex:1;">
                                        <div id="mp-cardExpirationYear" class="mp-field-wrapper"></div>
                                    </div>
                                    <div style="flex:1;">
                                        <div id="mp-securityCode" class="mp-field-wrapper"></div>
                                    </div>
                                </div>
                            </div>

                            @* ── Últimos 4 dígitos (apenas para conferência) ──────────── *@
                            <div style="margin-top:0.4rem;font-size:0.78rem;color:#6B7280;display:flex;align-items:center;gap:0.3rem;">
                                <span>🔒</span>
                                <span>Seus dados são enviados diretamente ao Mercado Pago — nunca passam pelo nosso servidor.</span>
                            </div>

                            @if (!string.IsNullOrEmpty(erroMpToken))
                            {
                                <div style="margin-top:0.4rem;font-size:0.78rem;color:#DC2626;display:flex;align-items:center;gap:0.3rem;">
                                    <span>⚠️</span>
                                    <span>@erroMpToken</span>
                                </div>
                            }
                        </div>
                    }
                    @if (metodoPagamento == "pix")
                    {
                        <div style="margin-top:0.6rem;font-size:0.8rem;color:var(--tp-text-muted);">
                            Um QR Code Pix será gerado após a confirmação.
                        </div>
                    }
                </div>

                <div class="vitrine-modal-divider"></div>

                <div class="vitrine-modal-row">
                    <span class="vitrine-modal-row-label">
                        @(ehMeiaEntrada ? "Preço meia-entrada" : "Preço")
                        @if (_selectedTicketType > 0 && tiposIngressoEvento != null)
                        {
                            var sel = tiposIngressoEvento.FirstOrDefault(t => t.Id == _selectedTicketType);
                            if (sel != null) { <text>· @sel.Nome</text> }
                        }
                    </span>
                    <span class="vitrine-modal-row-value">@PrecoBase.ToString("C")</span>
                </div>
                @if (contratarSeguro)
                {
                    <div class="vitrine-modal-row">
                        <span class="vitrine-modal-row-label">Seguro (+15%)</span>
                        <span class="vitrine-modal-row-value">+@((PrecoBase * 0.15m).ToString("C"))</span>
                    </div>
                }
                <div class="vitrine-modal-row">
                    <span class="vitrine-modal-row-label">Taxa de serviço</span>
                    <span class="vitrine-modal-row-value">+@Evento.TaxaServico.ToString("C")</span>
                </div>
                <div class="vitrine-modal-row" style="border-top:1.5px solid #E5E7EB;margin-top:0.3rem;padding-top:0.5rem;">
                    <span style="font-weight:700;color:#1a1a2e;">Total estimado</span>
                    <span style="font-weight:800;color:#5B5BD6;font-size:1.05rem;">@((PrecoBase + Evento.TaxaServico + (contratarSeguro ? PrecoBase * 0.15m : 0m)).ToString("C"))</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(cupomDigitado))
                {
                    <div style="font-size:0.75rem;color:#059669;margin-top:0.3rem;">
                        * Desconto do cupom aplicado no servidor. Valor final pode ser menor.
                    </div>
                }

                <div class="vitrine-modal-actions">
                    <button class="vitrine-modal-btn-primary"
                            @onclick="Comprar"
                            disabled="@(comprando)"
                            aria-label="Confirmar compra de ingresso para @Evento.Nome">
                        @if (comprando)
                        {
                            <span style="display:flex;align-items:center;gap:0.4rem;justify-content:center;">
                                <span style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 0.8s linear infinite;display:inline-block;"></span>
                                Comprando...
                            </span>
                        }
                        else
                        {
                            <span>Confirmar compra</span>
                        }
                    </button>
                    <button class="vitrine-modal-btn-sec" @onclick="FecharModal" disabled="@(comprando)" aria-label="Cancelar compra">Cancelar</button>
                </div>
            }
        </div>
    </div>
}

@code {
    // ═══════════════════════════════════════════════════════════════════
    //  Parameters
    // ═══════════════════════════════════════════════════════════════════

    /// <summary>Whether the modal is visible.</summary>
    [Parameter]
    public bool Visible { get; set; }

    /// <summary>Two-way binding callback for visibility.</summary>
    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>The event to purchase a ticket for.</summary>
    [Parameter]
    public TicketEvent Evento { get; set; } = null!;

    /// <summary>Optional callback invoked after a successful purchase.</summary>
    [Parameter]
    public EventCallback OnCompraConcluida { get; set; }

    // ═══════════════════════════════════════════════════════════════════
    //  State
    // ═══════════════════════════════════════════════════════════════════

    private bool comprando;
    private bool compraSucesso;
    private bool contratarSeguro;
    private bool ehMeiaEntrada;
    private string? erroCompra;
    private string cupomDigitado = "";

    // Documento comprobatório (meia-entrada)
    private string? documentoBase64;
    private string? documentoContentType;
    private string? nomeDocumento;
    private string? tamanhoDocumento;
    private string? erroDocumento;

    // Setor selecionado na compra
    private int _selectedTicketType;
    private List<TicketTypeDetailDto>? tiposIngressoEvento;

    // Pagamento
    private string metodoPagamento = "pix";
    private string? nomeTitular;
    private string? ultimos4Cartao;
    private string? cardToken;
    private bool cardTokenizing;
    private string? erroMpToken;
    private bool mpFieldsInitialized;

    // PIX QR Code
    private string? pixChavePix;
    private string? pixQrCodeBase64;

    private decimal PrecoBase
    {
        get
        {
            if (Evento == null) return 0;

            // Se há tipos de ingresso carregados e um está selecionado, usa o preço do setor
            if (tiposIngressoEvento != null && _selectedTicketType > 0)
            {
                var sel = tiposIngressoEvento.FirstOrDefault(t => t.Id == _selectedTicketType);
                if (sel != null)
                    return ehMeiaEntrada ? sel.Preco / 2 : sel.Preco;
            }

            // Fallback para o preço padrão do evento
            return ehMeiaEntrada
                ? Evento.PrecoPadrao / 2
                : Evento.PrecoPadrao;
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Lifecycle
    // ═══════════════════════════════════════════════════════════════════

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && Evento != null)
        {
            await CarregarTiposIngresso();
        }
    }

    private async Task CarregarTiposIngresso()
    {
        try
        {
            tiposIngressoEvento = null;
            _selectedTicketType = 0;
            var detalhe = await Http.GetFromJsonAsync<EventDetailDto>($"api/eventos/{Evento.Id}");
            if (detalhe?.TiposIngresso is { Count: > 0 })
            {
                tiposIngressoEvento = detalhe.TiposIngresso;
                _selectedTicketType = tiposIngressoEvento.OrderBy(t => t.Ordem).First().Id;
            }
        }
        catch
        {
            // Se não conseguir carregar, compra sem setores
            tiposIngressoEvento = null;
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Modal actions
    // ═══════════════════════════════════════════════════════════════════

    private async Task FecharModal()
    {
        await VisibleChanged.InvokeAsync(false);
        _ = UnmountMpFields();
        if (compraSucesso)
        {
            await OnCompraConcluida.InvokeAsync();
            Navigation.NavigateTo("/perfil");
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Documento comprobatório
    // ═══════════════════════════════════════════════════════════════════

    private async Task OnDocumentoSelecionado(InputFileChangeEventArgs e)
    {
        erroDocumento = null;

        var file = e.File;
        if (file == null) return;

        if (file.Size > 10 * 1024 * 1024)
        {
            erroDocumento = "O arquivo excede o limite de 10 MB.";
            return;
        }

        var allowedTypes = new[] { "image/jpeg", "image/jpg", "image/png", "image/webp", "application/pdf" };
        if (!allowedTypes.Contains(file.ContentType, StringComparer.OrdinalIgnoreCase))
        {
            erroDocumento = "Formato não aceito. Use JPEG, PNG, WebP ou PDF.";
            return;
        }

        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            documentoBase64 = Convert.ToBase64String(ms.ToArray());
            documentoContentType = file.ContentType;
            nomeDocumento = file.Name;

            tamanhoDocumento = file.Size switch
            {
                < 1024 => $"{file.Size} B",
                < 1024 * 1024 => $"{file.Size / 1024.0:F1} KB",
                _ => $"{file.Size / (1024.0 * 1024.0):F1} MB"
            };
        }
        catch (Exception ex)
        {
            erroDocumento = $"Erro ao ler o arquivo: {ex.Message}";
            documentoBase64 = null;
            documentoContentType = null;
            nomeDocumento = null;
            tamanhoDocumento = null;
        }
    }

    private void RemoverDocumento()
    {
        documentoBase64 = null;
        documentoContentType = null;
        nomeDocumento = null;
        tamanhoDocumento = null;
        erroDocumento = null;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Mercado Pago — Card Tokenization via JS Interop
    // ═══════════════════════════════════════════════════════════════════

    private async Task OnMetodoPagamentoChanged(string metodo)
    {
        nomeTitular = null;
        ultimos4Cartao = null;
        cardToken = null;
        erroMpToken = null;

        if (metodoPagamento is "cartao_credito" or "cartao_debito")
        {
            await UnmountMpFields();
        }

        metodoPagamento = metodo;

        if (metodo is "cartao_credito" or "cartao_debito")
        {
            await InitMpFields();
        }
    }

    private async Task InitMpFields()
    {
        if (mpFieldsInitialized) return;

        var mpPublicKey = Configuration["MercadoPago:PublicKey"];
        if (string.IsNullOrWhiteSpace(mpPublicKey))
        {
            erroMpToken = "Mercado Pago não configurado (chave pública ausente). Contate o administrador.";
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("TicketPrimeMp.init", mpPublicKey, "mp-card-fields-container");
            mpFieldsInitialized = true;
            erroMpToken = null;
        }
        catch (Exception ex)
        {
            erroMpToken = $"Erro ao carregar campos do cartão: {ex.Message}";
            Logger.LogError(ex, "Falha ao inicializar Mercado Pago Fields");
        }
    }

    private async Task UnmountMpFields()
    {
        if (!mpFieldsInitialized) return;

        try
        {
            await JS.InvokeVoidAsync("TicketPrimeMp.unmount");
        }
        catch
        {
            // Ignore errors during unmount
        }
        finally
        {
            mpFieldsInitialized = false;
        }
    }

    private async Task<string?> CreateCardTokenAsync()
    {
        if (!mpFieldsInitialized)
        {
            erroMpToken = "Campos do cartão não foram carregados. Selecione o cartão novamente.";
            return null;
        }

        cardTokenizing = true;
        erroMpToken = null;

        try
        {
            var result = await JS.InvokeAsync<MpTokenResult>("TicketPrimeMp.createCardToken");
            cardToken = result.token;
            ultimos4Cartao = result.lastFourDigits;
            return result.token;
        }
        catch (Exception ex)
        {
            erroMpToken = $"Erro ao gerar token do cartão: {ex.Message}";
            Logger.LogWarning(ex, "Falha ao criar card token MP");
            return null;
        }
        finally
        {
            cardTokenizing = false;
        }
    }

    private class MpTokenResult
    {
        public string token { get; set; } = string.Empty;
        public string lastFourDigits { get; set; } = string.Empty;
    }

    // ═══════════════════════════════════════════════════════════════════
    //  Purchase
    // ═══════════════════════════════════════════════════════════════════

    private async Task Comprar()
    {
        if (Evento == null) return;

        // ── Se for pagamento com cartão, tokeniza primeiro ──────────
        if (metodoPagamento is "cartao_credito" or "cartao_debito")
        {
            if (string.IsNullOrWhiteSpace(nomeTitular))
            {
                erroCompra = "Informe o nome do titular do cartão.";
                return;
            }

            var token = await CreateCardTokenAsync();
            if (string.IsNullOrEmpty(token))
            {
                if (string.IsNullOrEmpty(erroMpToken))
                    erroCompra = "Não foi possível processar o cartão. Verifique os dados e tente novamente.";
                else
                    erroCompra = erroMpToken;
                return;
            }
        }

        comprando = true;
        erroCompra = null;

        try
        {
            var dto = new PurchaseTicketDto
            {
                EventoId = Evento.Id,
                CupomUtilizado = string.IsNullOrWhiteSpace(cupomDigitado) ? null : cupomDigitado.Trim(),
                ContratarSeguro = contratarSeguro,
                EhMeiaEntrada = ehMeiaEntrada,
                TicketTypeId = _selectedTicketType > 0 ? _selectedTicketType : 1,
                MetodoPagamento = metodoPagamento,
                CardToken = cardToken,
                NomeTitular = string.IsNullOrWhiteSpace(nomeTitular) ? null : nomeTitular.Trim(),
                Ultimos4Cartao = string.IsNullOrWhiteSpace(ultimos4Cartao) ? null : ultimos4Cartao.Trim(),
                DocumentoBase64 = ehMeiaEntrada ? documentoBase64 : null,
                DocumentoNome = ehMeiaEntrada ? nomeDocumento : null,
                DocumentoContentType = ehMeiaEntrada ? documentoContentType : null
            };

            var json = JsonSerializer.Serialize(dto);
            var content = new StringContent(json, Encoding.UTF8, "application/json");
            var response = await Http.PostAsync("api/reservas", content);

            if (response.IsSuccessStatusCode)
            {
                compraSucesso = true;

                // ── Extrai chavePix para pagamentos PIX ────────────────
                try
                {
                    var body = await response.Content.ReadAsStringAsync();
                    var result = JsonSerializer.Deserialize<JsonElement>(body);
                    if (result.TryGetProperty("chavePix", out var chavePixProp) &&
                        chavePixProp.ValueKind == JsonValueKind.String)
                    {
                        pixChavePix = chavePixProp.GetString();
                        if (!string.IsNullOrEmpty(pixChavePix))
                        {
                            pixQrCodeBase64 = GerarQrCodePix(pixChavePix);
                        }
                    }
                }
                catch
                {
                    // Falha ao extrair chavePix não impede a compra
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
            {
                erroCompra = "⏳ Muitas requisições. Aguarde um instante e tente novamente.";
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                var err = JsonSerializer.Deserialize<JsonElement>(body);
                erroCompra = err.TryGetProperty("mensagem", out var msg) ? msg.GetString() : "Erro ao comprar ingresso.";
            }
        }
        catch (HttpRequestException)
        {
            erroCompra = "❌ Erro de conexão com o servidor.";
        }
        catch (Exception ex)
        {
            erroCompra = $"❌ Erro inesperado: {ex.Message}";
        }
        finally
        {
            comprando = false;
        }
    }

    // ═══════════════════════════════════════════════════════════════════
    //  PIX QR Code
    // ═══════════════════════════════════════════════════════════════════

    private static string GerarQrCodePix(string chavePix)
    {
        using var generator = new QRCodeGenerator();
        var data = generator.CreateQrCode(chavePix, QRCodeGenerator.ECCLevel.M);
        using var qr = new PngByteQRCode(data);
        return Convert.ToBase64String(qr.GetGraphic(4));
    }

    private async Task CopiarChavePix()
    {
        if (string.IsNullOrEmpty(pixChavePix)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", pixChavePix);
        }
        catch
        {
            try
            {
                await JS.InvokeVoidAsync("eval", $"navigator.clipboard.writeText('{pixChavePix.Replace("'", "\\'")}')");
            }
            catch
            {
                // Clipboard não disponível — o usuário pode copiar manualmente
            }
        }
    }
}
