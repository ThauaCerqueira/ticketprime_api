@using Microsoft.Extensions.Configuration
@inject NavigationManager Navigation
@inject IConfiguration Configuration

@* ──────────────────────────────────────────────────────────────────────────
   SEO / Open Graph / Twitter Card meta tags
   Reusable component for social media previews (WhatsApp, Facebook, Twitter).
   Use on any page that needs rich link previews.
   
   Parameters:
     Title        — (required) Page title for OG/Twitter
     Description  — (required) Page description for OG/Twitter (max ~200 chars)
     ImageUrl     — (optional) Full absolute URL to the preview image.
                    If omitted and EventId is set, constructs URL from
                    ApiSettings:BaseUrl + /api/public/eventos/{id}/thumbnail
     EventId      — (optional) Event ID to auto-generate thumbnail URL
     PageUrl      — (optional) Override canonical URL; defaults to current page
   ────────────────────────────────────────────────────────────────────────── *@

@if (!string.IsNullOrEmpty(Title))
{
    var absoluteUrl = PageUrl ?? Navigation.Uri;
    var siteName = "TicketPrime";
    var ogDescription = Description ?? Title;
    if (ogDescription?.Length > 300)
    {
        ogDescription = ogDescription[..297] + "...";
    }

    // Construct image URL
    string? ogImageUrl = ImageUrl;
    if (string.IsNullOrEmpty(ogImageUrl) && EventId.HasValue)
    {
        var apiBase = Configuration["ApiSettings:BaseUrl"]?.TrimEnd('/') ?? "";
        if (!string.IsNullOrEmpty(apiBase))
        {
            ogImageUrl = $"{apiBase}/api/public/eventos/{EventId.Value}/thumbnail";
        }
    }

    <HeadContent>
        @* ── Meta description ──────────────────────────────────── *@
        <meta name="description" content="@ogDescription" />
        <meta name="keywords" content="ingressos, eventos, shows, ticketprime, @Title" />

        @* ── Open Graph ────────────────────────────────────────── *@
        <meta property="og:title" content="@Title" />
        <meta property="og:description" content="@ogDescription" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="@absoluteUrl" />
        <meta property="og:site_name" content="@siteName" />
        <meta property="og:locale" content="pt_BR" />
        @if (!string.IsNullOrEmpty(ogImageUrl))
        {
            <meta property="og:image" content="@ogImageUrl" />
            <meta property="og:image:width" content="1200" />
            <meta property="og:image:height" content="630" />
            <meta property="og:image:type" content="@GetImageMimeType(ogImageUrl)" />
        }

        @* ── Twitter Card ──────────────────────────────────────── *@
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="@Title" />
        <meta name="twitter:description" content="@ogDescription" />
        @if (!string.IsNullOrEmpty(ogImageUrl))
        {
            <meta name="twitter:image" content="@ogImageUrl" />
        }

        @* ── Canonical URL ─────────────────────────────────────── *@
        <link rel="canonical" href="@absoluteUrl" />
    </HeadContent>
}

@code {
    /// <summary>
    /// Título da página para OG:title e Twitter:title.
    /// Obrigatório — sem ele, nenhuma tag é renderizada.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Descrição da página para meta description, OG:description e Twitter:description.
    /// Máximo recomendado: ~200 caracteres.
    /// </summary>
    [Parameter]
    public string? Description { get; set; }

    /// <summary>
    /// URL absoluta completa da imagem de preview (og:image / twitter:image).
    /// Se não informada e EventId for fornecido, constrói automaticamente
    /// a partir de ApiSettings:BaseUrl + /api/public/eventos/{id}/thumbnail.
    /// </summary>
    [Parameter]
    public string? ImageUrl { get; set; }

    /// <summary>
    /// ID do evento para gerar automaticamente a URL do thumbnail
    /// via endpoint público /api/public/eventos/{id}/thumbnail.
    /// </summary>
    [Parameter]
    public int? EventId { get; set; }

    /// <summary>
    /// URL canônica / OG:url. Se não informada, usa a URL atual da página.
    /// </summary>
    [Parameter]
    public string? PageUrl { get; set; }

    private static string GetImageMimeType(string url)
    {
        if (url.EndsWith(".png", StringComparison.OrdinalIgnoreCase)) return "image/png";
        if (url.EndsWith(".webp", StringComparison.OrdinalIgnoreCase)) return "image/webp";
        if (url.EndsWith(".gif", StringComparison.OrdinalIgnoreCase)) return "image/gif";
        if (url.EndsWith(".svg", StringComparison.OrdinalIgnoreCase)) return "image/svg+xml";
        return "image/jpeg";
    }
}
