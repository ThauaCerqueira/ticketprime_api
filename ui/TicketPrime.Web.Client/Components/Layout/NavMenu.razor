@using TicketPrime.Web.Client.Services
@inject SessionService Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable
<style>
    .navbar-top {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 64px;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
        background: var(--tp-navbar-bg);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--tp-navbar-border);
    }

    .navbar-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        cursor: pointer;
    }

    .navbar-logo-icon {
        width: 36px; height: 36px;
        background: var(--tp-primary);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .navbar-logo-icon svg { width: 18px; height: 18px; fill: white; }

    .navbar-logo-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--tp-text-heading);
    }

    .navbar-right {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        position: relative;
    }

    .navbar-user-info {
        font-size: 0.875rem;
        color: var(--tp-text-muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
        min-width: 0;
    }

    .navbar-user-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .navbar-user-badge {
        background: var(--tp-primary-light);
        color: var(--tp-primary);
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .navbar-dots-btn {
        width: 40px; height: 40px;
        background: transparent;
        border: 1.5px solid var(--tp-border);
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-direction: column;
        gap: 4px;
        padding: 0;
    }

    .navbar-dots-btn:hover {
        background: var(--tp-primary-light);
        border-color: var(--tp-primary);
    }

    .navbar-dots-btn span {
        width: 4px; height: 4px;
        background: var(--tp-text-body);
        border-radius: 50%;
        display: block;
        transition: background 0.2s;
    }

    .navbar-dots-btn:hover span { background: var(--tp-primary); }

    /* ── Botão de alternância de tema ─────────────────────────────────── */
    .navbar-theme-btn {
        width: 40px; height: 40px;
        background: transparent;
        border: 1.5px solid var(--tp-border);
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        padding: 0;
        color: var(--tp-text-body);
        flex-shrink: 0;
    }

    .navbar-theme-btn:hover {
        background: var(--tp-primary-light);
        border-color: var(--tp-primary);
        color: var(--tp-primary);
    }

    .navbar-theme-btn svg {
        width: 20px;
        height: 20px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .navbar-theme-btn .theme-sun { display: block; }
    .navbar-theme-btn .theme-moon { display: none; }

    [data-theme="dark"] .navbar-theme-btn .theme-sun { display: none; }
    [data-theme="dark"] .navbar-theme-btn .theme-moon { display: block; }

    .navbar-dropdown {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        background: var(--tp-bg-card);
        border-radius: 16px;
        box-shadow: var(--tp-shadow-lg);
        border: 1.5px solid var(--tp-border-card);
        min-width: 220px;
        overflow: hidden;
        animation: dropIn 0.15s ease;
        z-index: 300;
    }

    @@keyframes dropIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .navbar-dropdown-header {
        padding: 1rem 1.2rem 0.8rem;
        border-bottom: 1px solid var(--tp-border-card);
    }

    .navbar-dropdown-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--tp-text-heading);
    }

    .navbar-dropdown-role {
        font-size: 0.75rem;
        color: var(--tp-text-muted);
        margin-top: 0.1rem;
    }

    .navbar-dropdown-item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.8rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--tp-text-body);
        cursor: pointer;
        background: transparent;
        border: none;
        width: 100%;
        text-align: left;
        text-decoration: none;
        transition: background 0.15s;
    }

    .navbar-dropdown-item:hover { background: var(--tp-bg-page); color: var(--tp-primary); }

    .navbar-dropdown-item svg {
        width: 17px; height: 17px;
        flex-shrink: 0;
        stroke: currentColor;
    }

    .navbar-dropdown-divider {
        height: 1px;
        background: var(--tp-border-card);
        margin: 0.3rem 0;
    }

    .navbar-dropdown-item-danger {
        color: #DC2626 !important;
    }

    .navbar-dropdown-item-danger:hover { background: #FEF2F2 !important; color: #DC2626 !important; }

    [data-theme="dark"] .navbar-dropdown-item-danger:hover { background: #3B1A1A !important; color: #FCA5A5 !important; }

    .navbar-dropdown-section {
        padding: 0.3rem 0;
    }

    .navbar-dropdown-section-label {
        padding: 0.4rem 1.2rem 0.2rem;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--tp-text-light);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .navbar-login-btn {
        padding: 0.5rem 1.2rem;
        background: var(--tp-primary);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
    }

    .navbar-login-btn:hover { background: var(--tp-primary-hover); color: white; }

    .navbar-overlay {
        position: fixed;
        inset: 0;
        z-index: 199;
    }

    /* ── Responsivo: Tablet (≤768px) ────────────────────────────────── */
    @@media (max-width: 768px) {
        .navbar-top {
            padding: 0 1.25rem;
        }
    }

    /* ── Responsivo: Mobile (≤480px) ────────────────────────────────── */
    @@media (max-width: 480px) {
        .navbar-top {
            padding: 0 0.875rem;
            height: 56px;
        }

        .navbar-logo-icon {
            width: 32px;
            height: 32px;
        }

        .navbar-logo-icon svg {
            width: 16px;
            height: 16px;
        }

        .navbar-logo-name {
            font-size: 0.95rem;
        }

        .navbar-user-info {
            gap: 0.3rem;
        }

        .navbar-user-name {
            display: none;
        }

        .navbar-user-badge {
            font-size: 0.65rem;
            padding: 0.15rem 0.5rem;
        }

        .navbar-dots-btn {
            width: 36px;
            height: 36px;
            gap: 3px;
        }

        .navbar-dots-btn span {
            width: 3.5px;
            height: 3.5px;
        }

        .navbar-theme-btn {
            width: 36px;
            height: 36px;
        }

        .navbar-theme-btn svg {
            width: 18px;
            height: 18px;
        }

        .navbar-dropdown {
            position: fixed;
            top: 56px;
            left: 0.75rem;
            right: 0.75rem;
            min-width: unset;
            width: auto;
            border-radius: 14px;
            max-height: calc(100vh - 80px);
            overflow-y: auto;
        }

        .navbar-dropdown-item {
            padding: 0.9rem 1rem;
            font-size: 0.95rem;
            min-height: 44px;
        }

        .navbar-dropdown-header {
            padding: 0.85rem 1rem 0.7rem;
        }

        .navbar-login-btn {
            padding: 0.45rem 1rem;
            font-size: 0.8rem;
        }
    }

    /* ── Responsivo: Mobile muito pequeno (≤360px) ──────────────────── */
    @@media (max-width: 360px) {
        .navbar-top {
            padding: 0 0.625rem;
        }

        .navbar-logo-name {
            font-size: 0.85rem;
        }

        .navbar-logo-icon {
            width: 28px;
            height: 28px;
        }

        .navbar-logo-icon svg {
            width: 14px;
            height: 14px;
        }

        .navbar-dropdown {
            left: 0.5rem;
            right: 0.5rem;
        }
    }
</style>

<nav class="navbar-top">
    <div class="navbar-logo" @onclick='() => Navigation.NavigateTo("/")' role="button" tabindex="0" aria-label="Ir para página inicial">
        <div class="navbar-logo-icon">
            <svg viewBox="0 0 24 24" role="img" aria-label="Logotipo TicketPrime"><path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4zM12 17.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>
        </div>
        <span class="navbar-logo-name">TicketPrime</span>
    </div>

    <div class="navbar-right">
        <!-- Alternador de tema -->
        <button class="navbar-theme-btn" @onclick="ToggleTheme" title="Alternar tema" aria-label="Alternar tema do site">
            <!-- Ícone de sol (tema claro) -->
            <svg class="theme-sun" viewBox="0 0 24 24" fill="none" role="img" aria-label="Alternar para tema claro">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <!-- Ícone de lua (tema escuro) -->
            <svg class="theme-moon" viewBox="0 0 24 24" fill="none" role="img" aria-label="Alternar para tema escuro">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
        </button>

        @if (Session.EstaLogado)
        {
            <div class="navbar-user-info">
                <span class="navbar-user-name">@Session.Nome</span>
                <span class="navbar-user-badge">@Session.Perfil</span>
            </div>

            <button class="navbar-dots-btn" @onclick="ToggleMenu" aria-label="Abrir menu do usuário">
                <span></span>
                <span></span>
                <span></span>
            </button>
        }

        @if (menuAberto)
        {
            <div class="navbar-overlay" @onclick="FecharMenu" role="button" tabindex="0" aria-label="Fechar menu"></div>
            <div class="navbar-dropdown">

                @if (Session.EstaLogado)
                {
                    <div class="navbar-dropdown-header">
                        <div class="navbar-dropdown-name">@Session.Nome</div>
                        <div class="navbar-dropdown-role">@Session.Perfil</div>
                    </div>
                }

                <div class="navbar-dropdown-section">
                    <button class="navbar-dropdown-item" @onclick='() => Navegar("/eventos")'>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        Eventos
                    </button>

                    @if (Session.EstaLogado)
                    {
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/perfil")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            Meu Perfil
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/favoritos")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z"/>
                            </svg>
                            Favoritos
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/fila-espera")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M12 2v20M2 12h20"/>
                            </svg>
                            Fila de Espera
                        </button>
                    }

                    @if (Session.EhAdmin)
                    {
                        <div class="navbar-dropdown-divider"></div>
                        <div class="navbar-dropdown-section-label">Admin</div>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/eventos/criar-seguro")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            Criar Evento
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/admin/checkin")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Check-in
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/admin/meia-entrada")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                            Meia-Entrada
                        </button>
                    }
                </div>

                @if (Session.EstaLogado)
                {
                    <div class="navbar-dropdown-divider"></div>
                    <div class="navbar-dropdown-section">
                        <button class="navbar-dropdown-item navbar-dropdown-item-danger" @onclick="Logout">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                            </svg>
                            Sair
                        </button>
                    </div>
                }
                else
                {
                    <div class="navbar-dropdown-divider"></div>
                    <div class="navbar-dropdown-section">
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/login")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
                            </svg>
                            Entrar
                        </button>
                        <button class="navbar-dropdown-item" @onclick='() => Navegar("/cadastro-user")'>
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                            </svg>
                            Criar conta
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</nav>

@code {
    private bool menuAberto = false;
    private Action? _onSessionChange;

    protected override void OnInitialized()
    {
        _onSessionChange = () => InvokeAsync(StateHasChanged);
        Session.OnChange += _onSessionChange;
    }

    private void ToggleMenu() => menuAberto = !menuAberto;
    private void FecharMenu() => menuAberto = false;

    private void Navegar(string url)
    {
        menuAberto = false;
        Navigation.NavigateTo(url);
    }

    private async Task Logout()
    {
        menuAberto = false;
        await Session.DeslogarAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        try
        {
            await JS.InvokeVoidAsync("ticketPrimeTheme.toggleTheme");
        }
        catch
        {
            // JS interop pode falhar durante pré-renderização
        }
    }

    void IDisposable.Dispose()
    {
        if (_onSessionChange != null)
        {
            Session.OnChange -= _onSessionChange;
        }
    }
}
