@page "/redefinir-senha"
@using System.Net.Http.Json
@using TicketPrime.Web.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<style>
    .reset-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #dde1f5 0%, #f5d6e8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .reset-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 2.5rem 2.5rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 8px 40px rgba(99, 102, 241, 0.10);
    }

    .reset-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .reset-logo-icon {
        width: 56px;
        height: 56px;
        background: #5B5BD6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.6rem;
    }

    .reset-logo-icon svg {
        width: 28px;
        height: 28px;
        fill: white;
    }

    .reset-logo-name {
        font-size: 1.3rem;
        font-weight: 600;
        color: #5B5BD6;
        letter-spacing: -0.3px;
    }

    .reset-title {
        text-align: center;
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .reset-subtitle {
        text-align: center;
        font-size: 0.875rem;
        color: #6B7280;
        margin-bottom: 1.8rem;
        line-height: 1.4;
    }

    .reset-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: 0.4rem;
        display: block;
    }

    .reset-input-wrapper {
        position: relative;
        margin-bottom: 1.2rem;
    }

    .reset-input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        width: 18px;
        height: 18px;
    }

    .reset-input {
        width: 100%;
        padding: 0.7rem 1rem 0.7rem 2.6rem;
        border: 1.5px solid #E5E7EB;
        border-radius: 10px;
        font-size: 0.95rem;
        color: #374151;
        background: #fff;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    .reset-input:focus {
        border-color: #5B5BD6;
    }

    .reset-input::placeholder {
        color: #9CA3AF;
    }

    .reset-btn {
        width: 100%;
        padding: 0.85rem;
        background: #5B5BD6;
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        margin-bottom: 1.2rem;
    }

    .reset-btn:hover {
        background: #4949c4;
    }

    .reset-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .reset-success {
        background: #D1FAE5;
        color: #065F46;
        border-radius: 8px;
        padding: 0.8rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
        text-align: center;
        line-height: 1.4;
    }

    .reset-error {
        background: #FEE2E2;
        color: #DC2626;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1rem;
        text-align: center;
    }

    .reset-back {
        text-align: center;
        font-size: 0.875rem;
        color: #6B7280;
    }

    .reset-back a {
        color: #5B5BD6;
        text-decoration: none;
        font-weight: 500;
    }

    .reset-password-hint {
        font-size: 0.75rem;
        color: #9CA3AF;
        margin-top: -0.8rem;
        margin-bottom: 1rem;
        text-align: left;
        padding-left: 0.2rem;
    }

    .reset-requirements {
        background: #F9FAFB;
        border: 1px solid #E5E7EB;
        border-radius: 8px;
        padding: 0.8rem 1rem;
        font-size: 0.75rem;
        color: #6B7280;
        margin-bottom: 1.2rem;
        line-height: 1.6;
    }

    .reset-requirements span {
        display: block;
    }

    .reset-requirements .valido {
        color: #059669;
    }

    .reset-requirements .invalido {
        color: #9CA3AF;
    }
</style>

<div class="reset-wrapper">
    <div class="reset-card">

        <div class="reset-logo">
            <div class="reset-logo-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Logotipo TicketPrime">
                    <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4zM12 17.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                </svg>
            </div>
            <span class="reset-logo-name">TicketPrime</span>
        </div>

        <div class="reset-title">Redefinir senha</div>
        <div class="reset-subtitle">
            Digite o código recebido por email e sua nova senha.
        </div>

        @if (!string.IsNullOrEmpty(mensagemSucesso))
        {
            <div class="reset-success">
                @mensagemSucesso
                <br /><br />
                <a href="/login" style="color: #065F46; font-weight: 600;">Clique aqui para fazer login</a>
            </div>
        }

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="reset-error">@erro</div>
        }

        @if (string.IsNullOrEmpty(mensagemSucesso))
        {
            <label class="reset-label">Email</label>
            <div class="reset-input-wrapper">
                <svg class="reset-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="M22 4L12 13 2 4"/>
                </svg>
                <input class="reset-input" type="email" @bind="email" placeholder="seu@email.com" />
            </div>

            <label class="reset-label">Código de redefinição</label>
            <div class="reset-input-wrapper">
                <svg class="reset-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <input class="reset-input" type="text" @bind="token" placeholder="Código recebido por email" />
            </div>

            <label class="reset-label">Nova senha</label>
            <div class="reset-input-wrapper">
                <svg class="reset-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <input class="reset-input" type="password" @bind="novaSenha" placeholder="Nova senha" />
            </div>

            <div class="reset-requirements">
                <span class="@(novaSenha.Length >= 8 ? "valido" : "invalido")">
                    @(novaSenha.Length >= 8 ? "✅" : "⬜") Mínimo 8 caracteres
                </span>
                <span class="@(novaSenha.Any(char.IsUpper) ? "valido" : "invalido")">
                    @(novaSenha.Any(char.IsUpper) ? "✅" : "⬜") Pelo menos 1 letra maiúscula
                </span>
                <span class="@(novaSenha.Any(char.IsLower) ? "valido" : "invalido")">
                    @(novaSenha.Any(char.IsLower) ? "✅" : "⬜") Pelo menos 1 letra minúscula
                </span>
                <span class="@(novaSenha.Any(char.IsDigit) ? "valido" : "invalido")">
                    @(novaSenha.Any(char.IsDigit) ? "✅" : "⬜") Pelo menos 1 número
                </span>
                <span class="@(novaSenha.Any(c => !char.IsLetterOrDigit(c)) ? "valido" : "invalido")">
                    @(novaSenha.Any(c => !char.IsLetterOrDigit(c)) ? "✅" : "⬜") Pelo menos 1 caractere especial
                </span>
            </div>

            <button class="reset-btn" @onclick="HandleRedefinir" disabled="@carregando">
                @if (carregando)
                {
                    <span>Redefinindo...</span>
                }
                else
                {
                    <span>Redefinir senha</span>
                }
            </button>
        }

        <div class="reset-back">
            <a href="/login">Voltar para o login</a>
        </div>

    </div>
</div>

@code {
    private string email = "";
    private string token = "";
    private string novaSenha = "";
    private string erro = "";
    private string mensagemSucesso = "";
    private bool carregando = false;

    private bool SenhaValida()
    {
        if (novaSenha.Length < 8) return false;
        if (!novaSenha.Any(char.IsUpper)) return false;
        if (!novaSenha.Any(char.IsLower)) return false;
        if (!novaSenha.Any(char.IsDigit)) return false;
        if (!novaSenha.Any(c => !char.IsLetterOrDigit(c))) return false;
        return true;
    }

    private async Task HandleRedefinir()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            erro = "Informe seu email.";
            return;
        }

        if (string.IsNullOrWhiteSpace(token))
        {
            erro = "Informe o código de redefinição recebido por email.";
            return;
        }

        if (!SenhaValida())
        {
            erro = "A senha não atende aos requisitos de segurança.";
            return;
        }

        carregando = true;
        erro = "";
        mensagemSucesso = "";

        try
        {
            var dto = new ResetPasswordRequest
            {
                Email = email.Trim(),
                Token = token.Trim(),
                NovaSenha = novaSenha
            };
            var response = await Http.PostAsJsonAsync("api/auth/redefinir-senha", dto);

            if (response.IsSuccessStatusCode)
            {
                mensagemSucesso = "Senha redefinida com sucesso!";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
            {
                erro = "Muitas tentativas. Aguarde um minuto e tente novamente.";
            }
            else
            {
                var errorBody = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                erro = errorBody?.Mensagem ?? "Erro ao redefinir senha. Verifique o código e tente novamente.";
            }
        }
        catch (Exception ex)
        {
            erro = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }
}
