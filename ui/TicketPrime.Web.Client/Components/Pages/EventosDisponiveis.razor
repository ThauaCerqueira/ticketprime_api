@page "/vitrine"
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Configuration
@using QRCoder
@using TicketPrime.Web.Client.Services
@using TicketPrime.Web.Shared.Models
@using TicketPrime.Web.Client.Components.Shared
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject ILogger<EventosDisponiveis> Logger
<PageTitle>Eventos Disponíveis - TicketPrime</PageTitle>

@* ── SEO / Open Graph ──────────────────────────────────────────────── *@
<SeoMetaTags Title="Eventos Disponíveis - TicketPrime"
             Description="Confira os melhores eventos, shows e espetáculos. Compre ingressos com segurança na TicketPrime."
             PageUrl="@Navigation.Uri" />

@* ── Schema.org JSON-LD (ItemList para SEO) ───────────────────────── *@
@if (eventosDisponiveis != null && eventosDisponiveis.Any())
{
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "ItemList",
        "itemListElement": [
            @foreach (var (item, index) in eventosDisponiveis.Select((e, i) => (e, i)))
            {
                <text>
                {
                    "@@type": "ListItem",
                    "position": @(index + 1),
                    "url": "@Navigation.BaseUri.TrimEnd('/')/evento/@item.Id"
                }@(index < eventosDisponiveis.Count() - 1 ? "," : "")
                </text>
            }
        ]
    }
    </script>
}

<div class="vitrine-wrapper">
    <div class="vitrine-header">
        <h2>Próximos Eventos</h2>
        <p>Confira os eventos disponíveis e garanta seu ingresso</p>
    </div>

    <!-- Barra de busca e filtros -->
    <div class="vitrine-filtros">
        <div class="vitrine-filtro-group">
            <input class="vitrine-filtro-input"
                   placeholder="🔍 Buscar por nome..."
                   @bind="filtroNome" @bind:after="FiltrarEventos" />
        </div>
        <div>
            <select class="vitrine-filtro-select"
                    @bind="filtroGenero" @bind:after="FiltrarEventos">
                <option value="">Todos os gêneros</option>
                <option>Rock</option><option>Sertanejo</option><option>Eletrônico</option>
                <option>Pop</option><option>Forró</option><option>MPB</option>
                <option>Jazz</option><option>Clássico</option><option>Funk</option>
            </select>
        </div>
        <div>
            <input type="date" class="vitrine-filtro-date"
                   @bind="filtroDataMin" @bind:after="FiltrarEventos" />
        </div>
        <div>
            <input type="date" class="vitrine-filtro-date"
                   @bind="filtroDataMax" @bind:after="FiltrarEventos" />
        </div>
        <button class="vitrine-filtro-btn-limpar"
                @onclick="LimparFiltros" aria-label="Limpar filtros de busca">Limpar</button>
    </div>

    @if (!string.IsNullOrEmpty(mensagemErro))
    {
        <div class="vitrine-alert vitrine-alert-error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            @mensagemErro
        </div>
    }

    @if (!string.IsNullOrEmpty(mensagemSucesso))
    {
        <div class="vitrine-alert vitrine-alert-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            @mensagemSucesso
        </div>
    }

    @if (carregando)
    {
        <div class="vitrine-grid" aria-busy="true" aria-label="Carregando eventos...">
            @for (int i = 0; i < 6; i++)
            {
                <div class="vitrine-skeleton-card">
                    <div class="vitrine-skeleton-img"></div>
                    <div class="vitrine-skeleton-body">
                        <div class="vitrine-skeleton-line" style="width:75%"></div>
                        <div class="vitrine-skeleton-line" style="width:55%"></div>
                        <div class="vitrine-skeleton-line" style="width:50%"></div>
                        <div class="vitrine-skeleton-line" style="height:36px;border-radius:10px;margin-top:0.6rem"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (eventosDisponiveis == null || !eventosDisponiveis.Any())
    {
        <div class="vitrine-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1.5" aria-hidden="true" focusable="false">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <h3>Nenhum evento disponível</h3>
            <p>Novos eventos serão adicionados em breve.</p>
        </div>
    }
    else
    {
        <div class="vitrine-grid">
            @foreach (var evento in eventosDisponiveis)
            {
                <div class="vitrine-card">
                    <a href="/evento/@evento.Id" style="text-decoration:none;display:contents;">
                    @if (!string.IsNullOrEmpty(evento.FotoThumbnailBase64))
                    {
                        <img class="vitrine-card-img"
                             src="data:image/jpeg;base64,@evento.FotoThumbnailBase64"
                             alt="@evento.Nome" loading="lazy" />
                    }
                    else
                    {
                        <div class="vitrine-card-img-placeholder">
                            🎵
                        </div>
                    }
                    </a>
                    <div class="vitrine-card-body">
                    <a href="/evento/@evento.Id" style="text-decoration:none;color:inherit;">
                        <h5>@evento.Nome</h5>
                    </a>
                    <div class="vitrine-card-info">
                        <div class="vitrine-card-row">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            @evento.DataEvento.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="vitrine-card-row">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            </svg>
                            @evento.CapacidadeTotal vagas
                        </div>
                        <div class="vitrine-card-price">@evento.PrecoPadrao.ToString("C")</div>
                    </div>
                    <div class="vitrine-card-actions">
                        <a href="/evento/@evento.Id" aria-label="Ver detalhes de @evento.Nome">
                            <button class="vitrine-btn-detalhes" aria-label="Ver detalhes de @evento.Nome">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                    <circle cx="12" cy="12" r="3"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
                                </svg>
                                Detalhes
                            </button>
                        </a>
                        @if (Session.EstaLogado)
                        {
                            <button class="vitrine-btn-comprar" @onclick="() => AbrirCompra(evento)" aria-label="Comprar ingresso para @evento.Nome">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                                    <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4z"/>
                                </svg>
                                Comprar
                            </button>
                        }
                    </div>
                    </div>
                </div>
            }
        </div>

        <!-- Paginação -->
        <div style="display:flex;align-items:center;justify-content:center;gap:1rem;margin-top:2rem;">
            <button style="padding:0.5rem 1.2rem;background:white;border:1.5px solid #E5E7EB;border-radius:10px;font-size:0.875rem;font-weight:600;color:#374151;cursor:pointer;transition:background 0.2s;"
                    @onclick="PaginaAnterior" disabled="@(paginaAtual <= 1 || carregando)" aria-label="Página anterior de eventos">← Anterior</button>
            <span style="font-size:0.875rem;color:#6B7280;">Página @paginaAtual</span>
            <button style="padding:0.5rem 1.2rem;background:#5B5BD6;border:none;border-radius:10px;font-size:0.875rem;font-weight:600;color:white;cursor:pointer;transition:background 0.2s;"
                    @onclick="ProximaPagina" disabled="@(temMenosQueUmaPagina || carregando)" aria-label="Próxima página de eventos">Próxima →</button>
        </div>
    }
</div>

@* ── Shared Purchase Modal ────────────────────────────────────── *@
<CompraModal Evento="@eventoParaCompra"
             Visible="@mostrarCompraModal"
             VisibleChanged="@OnCompraModalVisibilityChanged"
             OnCompraConcluida="@OnCompraConcluida" />

@code {
    private List<TicketEvent>? eventosDisponiveis;
    private bool carregando = true;
    private string? mensagemErro;
    private string? mensagemSucesso;
    private int paginaAtual = 1;
    private const int TamanhoPagina = 12;
    private bool temMenosQueUmaPagina => (eventosDisponiveis?.Count ?? 0) < TamanhoPagina;

    // Filtros
    private string filtroNome = "";
    private string filtroGenero = "";
    private DateTime? filtroDataMin;
    private DateTime? filtroDataMax;

    // ── Shared purchase modal ─────────────────────────────────────────
    private bool mostrarCompraModal;
    private TicketEvent? eventoParaCompra;

    protected override async Task OnInitializedAsync()
    {
        await CarregarEventos();
    }

    private async Task FiltrarEventos()
    {
        paginaAtual = 1;
        await CarregarEventos();
    }

    private async Task LimparFiltros()
    {
        filtroNome = "";
        filtroGenero = "";
        filtroDataMin = null;
        filtroDataMax = null;
        paginaAtual = 1;
        await CarregarEventos();
    }

    private async Task PaginaAnterior()
    {
        if (paginaAtual > 1) { paginaAtual--; await CarregarEventos(); }
    }

    private async Task ProximaPagina()
    {
        paginaAtual++;
        await CarregarEventos();
    }

    private async Task CarregarEventos()
    {
        carregando = true;
        mensagemErro = null;

        try
        {
            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(filtroNome)) qs.Add($"nome={Uri.EscapeDataString(filtroNome)}");
            if (!string.IsNullOrWhiteSpace(filtroGenero)) qs.Add($"genero={Uri.EscapeDataString(filtroGenero)}");
            if (filtroDataMin.HasValue) qs.Add($"dataMin={filtroDataMin.Value:yyyy-MM-dd}");
            if (filtroDataMax.HasValue) qs.Add($"dataMax={filtroDataMax.Value:yyyy-MM-dd}");
            qs.Add($"pagina={paginaAtual}");
            qs.Add($"tamanhoPagina={TamanhoPagina}");
            var url = "api/eventos/disponiveis" + (qs.Any() ? "?" + string.Join("&", qs) : "");

            var result = await Http.GetFromJsonAsync<PaginatedResult<TicketEvent>>(url);
            eventosDisponiveis = result?.Itens ?? [];
        }
        catch (HttpRequestException ex)
        {
            mensagemErro = $"Erro ao carregar eventos: {ex.Message}";
        }
        catch (TaskCanceledException)
        {
            mensagemErro = "A requisição excedeu o tempo limite. Tente novamente.";
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao carregar eventos: {ex.Message}";
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task AbrirCompra(TicketEvent evento)
    {
        eventoParaCompra = evento;
        mostrarCompraModal = true;
    }

    private async Task OnCompraModalVisibilityChanged(bool visible)
    {
        mostrarCompraModal = visible;
        if (!visible)
        {
            mensagemSucesso = $"✅ Ingresso comprado com sucesso!";
            await CarregarEventos();
        }
    }

    private async Task OnCompraConcluida()
    {
        mensagemSucesso = $"✅ Ingresso comprado com sucesso!";
        await CarregarEventos();
    }
}
