@page "/cadastro-user"
@using System.Net.Http.Json
@using TicketPrime.Web.Shared.Models
@using TicketPrime.Web.Client.Services
@using FluentValidation
@inject HttpClient Http
@inject NavigationManager Navigation
@inject SessionService Session
@inject IValidator<RegistrationRequest> Validator

<PageTitle>Criar Conta - TicketPrime</PageTitle>

<div class="cu-wrapper">

    <div class="cu-header">
        <a href="/" class="cu-header-logo">
            <div class="cu-header-logo-icon">
                <svg viewBox="0 0 24 24" role="img" aria-label="Logotipo TicketPrime"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
            </div>
            <span class="cu-header-logo-name">TicketPrime</span>
        </a>
        <h2>Crie sua conta</h2>
        <p>Comece a comprar ingressos em segundos</p>
    </div>

    @if (emailCadastrado != null)
    {
        <div class="cu-card">
            <div class="cu-card-body" style="text-align:center;padding:2rem 1.5rem;">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--tp-primary)" stroke-width="1.5" style="margin-bottom:1rem;" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.5rem;">Verifique seu e-mail</h3>
                <p style="color:var(--tp-text-body);margin-bottom:0.25rem;">
                    Enviamos um link de ativação para:
                </p>
                <p style="font-weight:600;color:var(--tp-primary);margin-bottom:1.25rem;">@emailCadastrado</p>
                <p style="font-size:0.875rem;color:var(--tp-text-muted);margin-bottom:1.5rem;">
                    Confirme seu e-mail antes de comprar ingressos.
                    Verifique também a pasta de spam.
                </p>

                @if (!string.IsNullOrEmpty(reenvioMensagem))
                {
                    <div class="cu-alert @(reenvioSucesso ? "cu-alert-success" : "cu-alert-error")" style="margin-bottom:1rem;">
                        @reenvioMensagem
                    </div>
                }

                <button class="cu-btn-save" style="margin-bottom:0.75rem;" @onclick="ReenviarEmail" disabled="@reenvioLoading">
                    @if (reenvioLoading) { <div class="cu-spinner"></div> <span>Enviando...</span> }
                    else { <span>Reenviar e-mail de verificação</span> }
                </button>

                <div class="cu-login-link">
                    <a href="/login">Ir para o login</a>
                </div>
            </div>
        </div>
    }
    else
    {
    <div class="cu-card">
        <EditForm Model="@novoCadastro" OnValidSubmit="@HandleRegistration" FormName="formCadastroUser">

            <div class="cu-card-body">

                @if (!string.IsNullOrEmpty(mensagem))
                {
                    <div class="cu-alert @(sucesso ? "cu-alert-success" : "cu-alert-error")">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                            @if (sucesso)
                            {
                                <polyline points="20 6 9 17 4 12"/>
                            }
                            else
                            {
                                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                            }
                        </svg>
                        @mensagem
                    </div>
                }

                <div class="cu-row">
                    <div class="cu-field">
                        <label class="cu-label">CPF</label>
                        <InputText @bind-Value="novoCadastro.Cpf"
                                   class="cu-input"
                                   placeholder="00000000000"
                                   maxlength="11"
                                   @oninput="FiltrarCpf" />
                    </div>
                    <div class="cu-field">
                        <label class="cu-label">Nome completo</label>
                        <InputText @bind-Value="novoCadastro.Nome" class="cu-input" placeholder="Seu nome" />
                    </div>
                </div>

                <div class="cu-field">
                    <label class="cu-label">E-mail</label>
                    <InputText @bind-Value="novoCadastro.Email" class="cu-input" placeholder="seu@email.com" />
                </div>

                <div class="cu-field">
                    <label class="cu-label">Senha</label>
                    <InputText @bind-Value="novoCadastro.Senha" type="password" class="cu-input" placeholder="Mínimo 8 caracteres (A-Z, a-z, 0-9)" />
                </div>

                <div class="cu-field">
                    <label class="cu-label">Confirmar senha</label>
                    <input type="password" @bind="confirmarSenha" class="cu-input @(senhaMismatch ? "invalid" : "")" placeholder="Repita a senha" />
                    @if (senhaMismatch)
                    {
                        <span class="cu-validation-msg">⚠️ As senhas não coincidem.</span>
                    }
                </div>

                <div style="display:flex;align-items:flex-start;gap:0.6rem;">
                    <input type="checkbox" id="termosCheck" @bind="termosAceitos"
                           style="margin-top:3px;width:16px;height:16px;accent-color:var(--tp-primary);cursor:pointer;" />
                    <label for="termosCheck" style="font-size:0.85rem;color:var(--tp-text-body);cursor:pointer;line-height:1.4;">
                        Li e aceito os <a href="/termos" style="color:var(--tp-primary);">Termos de Uso</a> e a
                        <a href="/privacidade" style="color:var(--tp-primary);">Política de Privacidade</a>.
                    </label>
                </div>

            </div>

            <div class="cu-footer">
                <button type="submit" class="cu-btn-save" disabled="@salvando">
                    @if (salvando)
                    {
                        <div class="cu-spinner"></div>
                        <span>Criando conta...</span>
                    }
                    else
                    {
                        <span>Criar conta grátis</span>
                    }
                </button>
                <div class="cu-login-link">
                    Já tem uma conta? <a href="/login">Entrar</a>
                </div>
            </div>

        </EditForm>
    </div>
    } @* fim else emailCadastrado *@
</div>

@code {
    private RegistrationRequest novoCadastro = new();
    private string mensagem = "";
    private bool sucesso = false;
    private bool salvando = false;
    private string confirmarSenha = "";
    private bool termosAceitos = false;
    private bool senhaMismatch => !string.IsNullOrEmpty(confirmarSenha) && novoCadastro.Senha != confirmarSenha;
    private string? emailCadastrado = null;
    private string reenvioMensagem = "";
    private bool reenvioSucesso = false;
    private bool reenvioLoading = false;

    protected override void OnInitialized()
    {
        if (Session.EstaLogado)
        {
            Navigation.NavigateTo("/eventos");
        }
    }

    private void FiltrarCpf(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString() ?? "";
        novoCadastro.Cpf = new string(valor.Where(char.IsDigit).Take(11).ToArray());
    }

    private async Task HandleRegistration()
    {
        salvando = true;
        mensagem = "";
        sucesso = false;

        // ── Validação FluentValidation ────────────────────────────────────────
        var validationResult = Validator.Validate(novoCadastro);
        if (!validationResult.IsValid)
        {
            mensagem = string.Join("<br/>", validationResult.Errors.Select(e => e.ErrorMessage));
            salvando = false;
            return;
        }

        if (novoCadastro.Senha != confirmarSenha)
        {
            mensagem = "As senhas não coincidem.";
            salvando = false;
            return;
        }

        if (!termosAceitos)
        {
            mensagem = "Você deve aceitar os Termos de Uso para continuar.";
            salvando = false;
            return;
        }

        try
        {
            var cpf = novoCadastro.Cpf;
            var senha = novoCadastro.Senha;

            // Cadastrar usuário via API
            var cadastroResponse = await Http.PostAsJsonAsync("api/usuarios", novoCadastro);

            if (!cadastroResponse.IsSuccessStatusCode)
            {
                var errorBody = await cadastroResponse.Content.ReadFromJsonAsync<ApiErrorResponse>();
                mensagem = errorBody?.Mensagem ?? "Erro ao criar conta. Verifique os dados e tente novamente.";
                return;
            }

            // Em vez de auto-login, exibe a tela de verificação de e-mail.
            // O backend exige EmailVerificado = true para compras, por isso não
            // adianta logar antes de confirmar o e-mail.
            emailCadastrado = novoCadastro.Email;
            novoCadastro = new RegistrationRequest();
        }
        catch (HttpRequestException ex)
        {
            mensagem = "Erro de conexão com o servidor: " + ex.Message;
        }
        catch (Exception ex)
        {
            mensagem = "Erro inesperado: " + ex.Message;
        }
        finally
        {
            salvando = false;
        }
    }

    private async Task ReenviarEmail()
    {
        if (emailCadastrado == null) return;
        reenvioLoading = true;
        reenvioMensagem = "";
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/solicitar-verificacao-email",
                new { Email = emailCadastrado });
            reenvioSucesso = response.IsSuccessStatusCode;
            reenvioMensagem = reenvioSucesso
                ? "E-mail reenviado! Verifique sua caixa de entrada."
                : "Não foi possível reenviar. Tente novamente em instantes.";
        }
        catch
        {
            reenvioSucesso = false;
            reenvioMensagem = "Erro ao conectar ao servidor.";
        }
        finally
        {
            reenvioLoading = false;
        }
    }
}
