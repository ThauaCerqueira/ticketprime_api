@page "/login"
@using System.Net.Http.Json
@using TicketPrime.Web.Shared.Models
@using TicketPrime.Web.Client.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject SessionService Session

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-logo">
            <div class="login-logo-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Logotipo TicketPrime">
                    <path d="M22 10V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v4a2 2 0 0 0 0 4v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0 0-4zM12 17.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm0-7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                </svg>
            </div>
            <span class="login-logo-name">TicketPrime</span>
        </div>

        <div class="login-title">Bem-vindo de volta!</div>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="login-error">@erro</div>
        }

        <label class="login-label">CPF</label>
        <div class="login-input-wrapper">
            <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            <input class="login-input" type="text" @bind="cpf" placeholder="000.000.000-00" maxlength="14" />
        </div>

        <label class="login-label">Senha</label>
        <div class="login-input-wrapper">
            <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input class="login-input" type="password" @bind="senha" placeholder="Digite sua senha" />
        </div>

        <div class="login-row">
            <a class="login-forgot" href="/recuperar-senha">Esqueceu a senha?</a>
        </div>

        <button class="login-btn" @onclick="HandleLogin" disabled="@carregando">
            @if (carregando)
            {
                <span>Entrando...</span>
            }
            else
            {
                <span>Entrar</span>
            }
        </button>

        <div class="login-register">
            Não tem uma conta? <a href="/cadastro-user">Criar cadastro</a>
        </div>

    </div>
</div>

@code {
    private string cpf = "";
    private string senha = "";
    private string erro = "";
    private bool carregando = false;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && Session.EstaLogado)
        {
            Navigation.NavigateTo("/eventos");
        }
    }

    private async Task HandleLogin()
    {
        cpf = new string(cpf.Where(char.IsDigit).ToArray());
        carregando = true;
        erro = "";

        try
        {
            var dto = new LoginRequest { Cpf = cpf, Senha = senha };
            var response = await Http.PostAsJsonAsync("api/auth/login", dto);

            if (response.IsSuccessStatusCode)
            {
                var resultado = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (resultado != null)
                {
                    // ══════════════════════════════════════════════════════════
                    // SEGURANÇA: Não passamos mais refreshToken.
                    // O refresh token agora é definido exclusivamente como
                    // cookie httpOnly pelo backend (ticketprime_refresh).
                    // O cookie é enviado automaticamente em todas as
                    // requisições para a API.
                    // ══════════════════════════════════════════════════════════
                    await Session.LogarAsync(resultado.Cpf, resultado.Nome, resultado.Perfil, resultado.Token);

                    if (resultado.SenhaTemporaria)
                    {
                        Session.MarcarSenhaTemporaria();
                        Navigation.NavigateTo("/trocar-senha");
                    }
                    else
                    {
                        Navigation.NavigateTo("/eventos");
                    }
                }
                else
                {
                    erro = "Resposta inválida do servidor.";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                erro = "CPF ou senha inválidos.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.TooManyRequests)
            {
                erro = "Muitas tentativas. Aguarde um minuto e tente novamente.";
            }
            else
            {
                var errorBody = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                erro = errorBody?.Mensagem ?? "Erro ao realizar login.";
            }
        }
        catch (Exception ex)
        {
            erro = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }
}
