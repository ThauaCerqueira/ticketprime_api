@page "/termos"
@layout EmptyLayout

<PageTitle>Termos de Uso - TicketPrime</PageTitle>

<div class="lgpd-wrapper">
    <div class="lgpd-card">
        <div class="lgpd-header">
            <a href="/" class="lgpd-logo">
