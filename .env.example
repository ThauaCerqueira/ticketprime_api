# ── Variáveis de ambiente para Docker Compose ──────────────────────────
# Copie este arquivo como .env e preencha os valores.
#   cp .env.example .env
#
# ⚠ NUNCA versionar o .env — ele contém senhas reais.
# ⚠ O .env.example pode ser versionado (sem senhas).

# ── SQL Server ─────────────────────────────────────────────────────────
# Senha do usuário SA (mínimo 8 caracteres, deve ter maiúscula, minúscula, número e especial)
SA_PASSWORD=TicketPrime@2024!

# Edição do SQL Server: Developer | Express | Standard | Enterprise
MSSQL_PID=Developer

# ── JWT ────────────────────────────────────────────────────────────────
# Chave secreta para assinatura dos tokens JWT (mínimo 32 caracteres)
JWT_KEY=ChaveJwtComPeloMenos32CaracteresAqui!!

# ── MinIO (S3-compatible storage para backups) ─────────────────────────
# Senha do admin do MinIO (console web em http://localhost:9001)
MINIO_ROOT_PASSWORD=MinioAdmin@2024!

# Senha do usuário de serviço ticketprime-backup (usada pelo backup.sh)
MINIO_BACKUP_SECRET=MinioBackup@2024!

# ── MinIO (storage de imagens de eventos, opcional) ────────────────────
# Descomente para ativar MinioStorageService em vez de LocalFileStorage.
# Se usar Docker Compose, o endpoint interno é minio:9000.
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=MinioAdmin@2024!
# MINIO_BUCKET=ticketprime
# MINIO_PUBLIC_URL=http://localhost:9000

# ── Email (opcional) ───────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=seu@email.com
# SMTP_PASSWORD=sua-senha
# SMTP_FROM_EMAIL=noreply@ticketprime.com
# SMTP_FROM_NAME=Ticket Prime
# SMTP_USE_SSL=true

# ── Mercado Pago (opcional em dev) ─────────────────────────────────────
# MP_ACCESS_TOKEN=TEST-123456789...
# MP_WEBHOOK_SECRET=...
