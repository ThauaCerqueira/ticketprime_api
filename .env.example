# ═══════════════════════════════════════════════════════════════════════════════
#  TicketPrime — Variáveis de Ambiente (Docker Compose)
#  ─────────────────────────────────────────────────────────────────────────────
#  Copie este arquivo como .env e preencha os valores.
#    cp .env.example .env
#
#  ⚠️ NUNCA versionar o .env (contém senhas reais).
#  ⚠️ Use senhas fortes em produção (geradas aleatoriamente).
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
#  OBRIGATÓRIOS — O Docker Compose NÃO sobe sem estes valores
# ═══════════════════════════════════════════════════════════════════════════════

# ── SQL Server ─────────────────────────────────────────────────────────
# Senha do usuário SA (mín. 8 chars, maiúscula + minúscula + número + especial)
SA_PASSWORD=TicketPrime@2024!

# ── JWT ────────────────────────────────────────────────────────────────
# Chave secreta JWT (mínimo 32 caracteres / 256 bits para HMAC-SHA256)
# Gere com: openssl rand -base64 32
JWT_KEY=ChaveJwtComPeloMenos32CaracteresAqui!!

# ═══════════════════════════════════════════════════════════════════════════════
#  RECOMENDADOS
# ═══════════════════════════════════════════════════════════════════════════════

# ── Edição do SQL Server ───────────────────────────────────────────────
# "Developer" (FTS disponível) | "Express" (sem Full-Text Search)
MSSQL_PID=Developer

# ── MinIO (S3-compatible storage) ──────────────────────────────────────
# Console web: http://localhost:9001 (login: admin / senha abaixo)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=MinioSenhaForteAqui!
MINIO_BACKUP_SECRET=ChaveSecretaBackupAqui!
MINIO_ROOT_PASSWORD=MinioAdmin@2024!

# Senha do usuário de serviço ticketprime-backup (usada pelo backup.sh)
MINIO_BACKUP_SECRET=MinioBackup@2024!

# ── MinIO (storage de imagens de eventos, opcional) ────────────────────
# Descomente para ativar MinioStorageService em vez de LocalFileStorage.
# Se usar Docker Compose, o endpoint interno é minio:9000.
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=MinioAdmin@2024!
# MINIO_BUCKET=ticketprime
# MINIO_PUBLIC_URL=http://localhost:9000

# ── Email (opcional) ───────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=seu@email.com
# SMTP_PASSWORD=sua-senha
# SMTP_FROM_EMAIL=noreply@ticketprime.com
# SMTP_FROM_NAME=Ticket Prime
# SMTP_USE_SSL=true

# ── Mercado Pago (opcional em dev) ─────────────────────────────────────
# MP_ACCESS_TOKEN=TEST-123456789...
# MP_WEBHOOK_SECRET=...
